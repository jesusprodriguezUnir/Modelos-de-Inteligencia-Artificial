<script is:inline>
  // Script para copiar al portapapeles de forma interactiva
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const codeEl = document.getElementById(targetId);
      if (codeEl) {
        navigator.clipboard.writeText(codeEl.textContent).then(() => {
          const originalText = btn.textContent;
          btn.textContent = '✅ Copiado!';
          btn.style.color = 'var(--pos)';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.color = 'var(--accent)';
          }, 2000);
        });
      }
    });
  });

  // Script interactivo para la lista de verificación
  const checkboxes = document.querySelectorAll('#checklist-container input[type="checkbox"]');
  const statusEl = document.getElementById('checklist-status');
  
  function updateChecklistStatus() {
    const checkedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
    const totalCount = checkboxes.length;
    
    if (checkedCount === 0) {
      statusEl.textContent = '0 de ' + totalCount + ' seleccionados. ¡Prepara tu prompt!';
      statusEl.style.color = 'var(--dim)';
    } else if (checkedCount === totalCount) {
      statusEl.textContent = '🎉 ¡Todo listo! Tu prompt está optimizado al máximo.';
      statusEl.style.color = 'var(--pos)';
    } else {
      statusEl.textContent = checkedCount + ' de ' + totalCount + ' optimizaciones comprobadas.';
      statusEl.style.color = 'var(--accent2)';
    }
  }

  checkboxes.forEach(cb => {
    cb.addEventListener('change', updateChecklistStatus);
  });
</script>
