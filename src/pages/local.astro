---
import Layout from '../layouts/Layout.astro';
import { models, companies } from '../data/models';

const openWeight = models.filter((m) => m.openWeight && m.kind === 'model');

// Formatters para frontmatter
const fmtCtx = (n: number | null) => (n == null ? '—' : n >= 1_000_000 ? `${n / 1_000_000}M` : `${Math.round(n / 1000)}K`);

// Snippets como strings: Astro los interpola como texto (las llaves no se evalúan).
const snOllama = `# Instalar (macOS/Linux)
curl -fsSL https://ollama.com/install.sh | sh

# Descargar y chatear con un modelo
ollama run qwen3.5:14b

# Servir API (arranca solo como servicio)
ollama serve   # -> http://localhost:11434`;

const snLlama = `# Servidor con API OpenAI-compatible
./llama-server -m modelo.Q4_K_M.gguf -c 8192 --port 8080`;

const snVllm = `# Servir un modelo desde Hugging Face
pip install vllm
vllm serve Qwen/Qwen3.5-14B-Instruct --port 8000
# -> http://localhost:8000/v1`;

const snPy = `from openai import OpenAI

client = OpenAI(base_url="http://localhost:11434/v1", api_key="local")
resp = client.chat.completions.create(
    model="qwen3.5:14b",
    messages=[{"role": "user", "content": "Refactoriza este repositorio EF Core"}],
)
print(resp.choices[0].message.content)`;

const snTs = `import OpenAI from "openai";

const client = new OpenAI({ baseURL: "http://localhost:11434/v1", apiKey: "local" });
const r = await client.chat.completions.create({
  model: "qwen3.5:14b",
  messages: [{ role: "user", content: "Genera tests xUnit para este servicio" }],
});
console.log(r.choices[0].message.content);`;

const snCs = `using OpenAI.Chat;
using System.ClientModel;

var client = new ChatClient(
    model: "qwen3.5:14b",
    credential: new ApiKeyCredential("local"),
    options: new OpenAIClientOptions { Endpoint = new Uri("http://localhost:11434/v1") });

ChatCompletion res = client.CompleteChat("Explica este stack trace de ASP.NET Core");
Console.WriteLine(res.Content[0].Text);`;

const snOpenCode = `// ~/.config/opencode/opencode.json
{
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": { "qwen3.5:14b": { "name": "Qwen 3.5 14B (local)" } }
    }
  }
}`;
---

<Layout title="Guía: Modelos locales — Catálogo de Modelos de IA" active="local">
  <main class="wrap" style="padding-top:24px; padding-bottom:150px;">
    <!-- cabecera hero -->
    <div style="margin-bottom:18px;">
      <h1 style="margin:0 0 6px; font-size:clamp(24px,3.4vw,34px); font-weight:700; color:var(--head); letter-spacing:-.5px;">💻 Ejecutar Modelos de IA Locales</h1>
      <p style="margin:0; color:var(--dim); font-size:14.5px; max-width:720px;">Cómo ejecutar modelos open-weight en tu propia máquina o servidor: runtimes, hardware, cuantización y cómo conectarlos a tu código y agentes.</p>
    </div>

    <!-- KPI strip -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:14px; margin-bottom:24px;">
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px 18px;">
        <div style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Motores Principales</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:32px; font-weight:600; color:var(--accent2); margin-top:7px;">4</div>
        <div style="font-size:13px; color:var(--head); margin-top:2px;">Ollama, LM Studio, vLLM, llama.cpp</div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px 18px;">
        <div style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">GPU Base Recomendada</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:32px; font-weight:600; color:var(--accent); margin-top:7px;">8 GB</div>
        <div style="font-size:13px; color:var(--head); margin-top:2px;">VRAM mínima para modelos de 7B/8B</div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px 18px;">
        <div style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Cuantización Estándar</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:32px; font-weight:600; color:var(--warn); margin-top:7px;">Q4_K_M</div>
        <div style="font-size:13px; color:var(--head); margin-top:2px;">El punto dulce entre calidad y tamaño</div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px 18px;">
        <div style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Endpoint Local</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:18px; font-weight:600; color:var(--pos); margin-top:19px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">localhost:11434</div>
        <div style="font-size:13px; color:var(--head); margin-top:7px;">API compatible con OpenAI</div>
      </div>
    </div>

    <!-- ¿Por qué local? -->
    <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:20px; margin-bottom:28px;">
      <h2 style="margin:0 0 12px; font-size:18px; font-weight:600; color:var(--head);">¿Por qué ejecutar modelos locales?</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:20px;">
        <div>
          <p style="color:var(--text); font-size:13.5px; line-height:1.6; margin:0 0 10px;">
            Ejecutar modelos en tu propia infraestructura ofrece ventajas estratégicas clave frente a las APIs propietarias en la nube:
          </p>
          <ul style="padding-left:18px; margin:0; color:var(--dim); font-size:13px; line-height:1.6;">
            <li style="margin-bottom:6px;"><b style="color:var(--head);">Privacidad Absoluta:</b> Tu código y datos sensibles no salen de tu red local, crucial para entornos corporativos regulados (banca, salud, defensa).</li>
            <li style="margin-bottom:6px;"><b style="color:var(--head);">Coste Marginal Cero:</b> Pagas la inversión en hardware inicial. No hay facturación recurrente por tokens ni límites de consumo mensuales.</li>
            <li style="margin-bottom:6px;"><b style="color:var(--head);">Baja Latencia y Offline:</b> Funciona de forma predecible sin conexión a internet y sin colas de rate limits de proveedores externos.</li>
          </ul>
        </div>
        <div style="background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:15px; display:flex; flex-direction:column; justify-content:center;">
          <span style="font-size:13px; font-weight:600; color:var(--accent); text-transform:uppercase; letter-spacing:.5px;">Regla práctica de arquitectura</span>
          <p style="color:var(--text); font-size:13.5px; line-height:1.5; margin:8px 0 0;">
            Usa <b>modelos locales para desarrollo diario, tareas repetitivas de volumen y procesamiento de datos sensibles</b>. Enruta a modelos frontera propietarios (Claude/GPT/Gemini) vía API solo para las tareas complejas de razonamiento o refactorizaciones multi-archivo muy difíciles.
          </p>
        </div>
      </div>
    </div>

    <!-- Runtimes: Motores de Ejecución -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; align-items:center; gap:10px; padding-bottom:12px; border-bottom:1px solid var(--border); margin-bottom:18px;">
        <span style="font-size:16px; font-weight:600; color:var(--head);">Runtimes: Motores de Ejecución</span>
        <span style="font-size:12px; color:var(--dim);">Elige el runtime adecuado según tu entorno</span>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:14px;">
        <!-- Ollama -->
        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; justify-content:space-between;">
          <div>
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
              <h3 style="margin:0; font-size:17px; font-weight:600; color:var(--head);">Ollama</h3>
              <span style="font-size:10px; font-weight:600; color:var(--pos); background:var(--panel2); border:1px solid var(--pos)33; border-radius:5px; padding:2px 7px;">★ Recomendado</span>
            </div>
            <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 14px;">El gestor local más popular y sencillo. Descarga, ejecuta y sirve modelos automáticamente con un endpoint compatible con OpenAI en el puerto 11434.</p>
          </div>
          <button class="dbtn runtime-toggle-btn" data-target="ollama-code" style="width:100%; font-family:inherit; font-size:12.5px; padding:8px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text); cursor:pointer;">Ver comandos de inicio</button>
        </div>

        <!-- LM Studio -->
        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; justify-content:space-between;">
          <div>
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
              <h3 style="margin:0; font-size:17px; font-weight:600; color:var(--head);">LM Studio</h3>
              <span style="font-size:10px; font-weight:600; color:var(--accent2); background:var(--panel2); border:1px solid var(--accent2)33; border-radius:5px; padding:2px 7px;">App de Escritorio</span>
            </div>
            <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 14px;">Interfaz gráfica (GUI) pulida para explorar, descargar de Hugging Face y chatear con modelos. También levanta servidores compatibles con OpenAI en local.</p>
          </div>
          <a href="https://lmstudio.ai" target="_blank" rel="noopener" class="dbtn" style="text-align:center; font-family:inherit; font-size:12.5px; padding:8px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text); text-decoration:none;">Descargar LM Studio ↗</a>
        </div>

        <!-- llama.cpp -->
        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; justify-content:space-between;">
          <div>
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
              <h3 style="margin:0; font-size:17px; font-weight:600; color:var(--head);">llama.cpp</h3>
              <span style="font-size:10px; font-weight:600; color:var(--warn); background:var(--panel2); border:1px solid var(--warn)33; border-radius:5px; padding:2px 7px;">Bajo nivel / Edge</span>
            </div>
            <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 14px;">Motor nativo en C/C++ hiper-optimizado para ejecutar cuantizaciones GGUF. Eficiente en CPU y base oculta de casi todas las herramientas locales.</p>
          </div>
          <button class="dbtn runtime-toggle-btn" data-target="llama-code" style="width:100%; font-family:inherit; font-size:12.5px; padding:8px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text); cursor:pointer;">Ver comandos de inicio</button>
        </div>

        <!-- vLLM -->
        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; justify-content:space-between;">
          <div>
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
              <h3 style="margin:0; font-size:17px; font-weight:600; color:var(--head);">vLLM</h3>
              <span style="font-size:10px; font-weight:600; color:var(--accent); background:var(--panel2); border:1px solid var(--accent)33; border-radius:5px; padding:2px 7px;">Producción</span>
            </div>
            <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 14px;">Motor de nivel de producción con alto rendimiento (PagedAttention). Ideal para servidores multi-usuario compartidos con GPUs empresariales.</p>
          </div>
          <button class="dbtn runtime-toggle-btn" data-target="vllm-code" style="width:100%; font-family:inherit; font-size:12.5px; padding:8px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text); cursor:pointer;">Ver comandos de inicio</button>
        </div>
      </div>

      <!-- Contenedores de código colapsables para los runtimes -->
      <div id="runtime-code-blocks" style="margin-top:14px;">
        <div id="ollama-code" class="runtime-code-panel hidden" style="background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:16px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
            <span style="font-size:12px; font-weight:600; color:var(--head);">Inicio rápido con Ollama</span>
            <button class="dbtn copy-snippet-btn" data-snippet={snOllama} style="margin-left:auto; font-family:inherit; font-size:11px; padding:4px 10px; border-radius:6px; border:1px solid var(--border2); background:var(--panel); color:var(--text);">Copiar comandos</button>
          </div>
          <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-bash">{snOllama}</code></pre>
        </div>

        <div id="llama-code" class="runtime-code-panel hidden" style="background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:16px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
            <span style="font-size:12px; font-weight:600; color:var(--head);">Inicio rápido con llama.cpp</span>
            <button class="dbtn copy-snippet-btn" data-snippet={snLlama} style="margin-left:auto; font-family:inherit; font-size:11px; padding:4px 10px; border-radius:6px; border:1px solid var(--border2); background:var(--panel); color:var(--text);">Copiar comando</button>
          </div>
          <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-bash">{snLlama}</code></pre>
        </div>

        <div id="vllm-code" class="runtime-code-panel hidden" style="background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:16px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
            <span style="font-size:12px; font-weight:600; color:var(--head);">Inicio rápido con vLLM</span>
            <button class="dbtn copy-snippet-btn" data-snippet={snVllm} style="margin-left:auto; font-family:inherit; font-size:11px; padding:4px 10px; border-radius:6px; border:1px solid var(--border2); background:var(--panel); color:var(--text);">Copiar comandos</button>
          </div>
          <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-bash">{snVllm}</code></pre>
        </div>
      </div>
    </div>

    <!-- Dimensionamiento de Hardware y VRAM -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; align-items:center; gap:10px; padding-bottom:12px; border-bottom:1px solid var(--border); margin-bottom:18px;">
        <span style="font-size:16px; font-weight:600; color:var(--head);">Dimensionamiento de Hardware y VRAM</span>
        <span style="font-size:12px; color:var(--dim);">Estimación de memoria requerida para precisión cuantizada Q4</span>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:14px;">
        <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px 18px;">
          <p style="color:var(--text); margin:0 0 12px; font-size:13.5px; line-height:1.65;">
            La <b>VRAM (memoria gráfica)</b> de tu tarjeta de video es el recurso crítico. Un modelo en precisión nativa (FP16) requiere unos <b>2 GB de VRAM por cada 1.000 millones (1B) de parámetros</b>. La cuantización reduce la precisión de los pesos (a 8, 4 o menos bits) para que el modelo ocupe un 75% menos de memoria con una pérdida de calidad mínima.
          </p>
          <div style="border-left:3px solid var(--brand); padding:10px 14px; background:var(--panel2); border-radius:0 8px 8px 0; font-size:13px; color:var(--text);">
            <b>El punto dulce:</b> la cuantización <code>Q4_K_M</code> reduce la necesidad a unos <b>0.6 - 0.7 GB por 1B de parámetros</b>. Añade ~1–3 GB extra para el contexto (KV-cache) en ventanas grandes.
          </div>
        </div>

        <div class="table-wrap">
          <table style="width:100%; border-collapse:collapse; min-width:640px;">
            <thead>
              <tr style="text-align:left; color:var(--dim);">
                <th style="padding:12px 16px; font-size:11px; font-weight:500; text-transform:uppercase; border-bottom:1px solid var(--border2);">Parámetros</th>
                <th style="padding:12px 16px; font-size:11px; font-weight:500; text-transform:uppercase; border-bottom:1px solid var(--border2);">VRAM Mínima (Q4)</th>
                <th style="padding:12px 16px; font-size:11px; font-weight:500; text-transform:uppercase; border-bottom:1px solid var(--border2);">GPU Recomendada (Local)</th>
                <th style="padding:12px 16px; font-size:11px; font-weight:500; text-transform:uppercase; border-bottom:1px solid var(--border2);">Apple Silicon (RAM Unificada)</th>
                <th style="padding:12px 16px; font-size:11px; font-weight:500; text-transform:uppercase; border-bottom:1px solid var(--border2);">Ejemplo de Modelo</th>
              </tr>
            </thead>
            <tbody>
              <tr class="drow" style="border-bottom:1px solid var(--border);">
                <td style="padding:11px 16px; color:var(--head); font-weight:500;">3B - 4B</td>
                <td style="padding:11px 16px; font-family:'IBM Plex Mono',monospace; color:var(--pos);">~3 - 4 GB</td>
                <td style="padding:11px 16px; color:var(--text);">GTX 1650 / RTX 3050 (Portátiles)</td>
                <td style="padding:11px 16px; color:var(--text);">Mac de 8 GB o superior</td>
                <td style="padding:11px 16px; color:var(--dim);">Qwen2.5-Coder 3B / Phi-4 (Mini)</td>
              </tr>
              <tr class="drow" style="border-bottom:1px solid var(--border);">
                <td style="padding:11px 16px; color:var(--head); font-weight:500;">7B - 8B</td>
                <td style="padding:11px 16px; font-family:'IBM Plex Mono',monospace; color:var(--pos);">~6 - 8 GB</td>
                <td style="padding:11px 16px; color:var(--text);">RTX 4060 / 3060 / RX 7600</td>
                <td style="padding:11px 16px; color:var(--text);">Mac de 16 GB o superior</td>
                <td style="padding:11px 16px; color:var(--dim);">Llama-3.1 8B / Qwen2.5-Coder 7B</td>
              </tr>
              <tr class="drow" style="border-bottom:1px solid var(--border);">
                <td style="padding:11px 16px; color:var(--head); font-weight:500;">14B - 15B</td>
                <td style="padding:11px 16px; font-family:'IBM Plex Mono',monospace; color:var(--pos);">~12 - 16 GB</td>
                <td style="padding:11px 16px; color:var(--text);">RTX 4070 / 4070 Ti / 4080 (16GB)</td>
                <td style="padding:11px 16px; color:var(--text);">Mac de 24 GB o superior</td>
                <td style="padding:11px 16px; color:var(--dim);">Qwen2.5-Coder 14B / GLM-4-9B</td>
              </tr>
              <tr class="drow" style="border-bottom:1px solid var(--border);">
                <td style="padding:11px 16px; color:var(--head); font-weight:500;">32B - 34B</td>
                <td style="padding:11px 16px; font-family:'IBM Plex Mono',monospace; color:var(--warn);">~20 - 24 GB</td>
                <td style="padding:11px 16px; color:var(--text);">RTX 3090 / 4090 / RX 7900 XTX</td>
                <td style="padding:11px 16px; color:var(--text);">Mac de 36 GB o superior</td>
                <td style="padding:11px 16px; color:var(--dim);">Qwen2.5-Coder 32B / Yi-Coder 34B</td>
              </tr>
              <tr class="drow" style="border-bottom:1px solid var(--border);">
                <td style="padding:11px 16px; color:var(--head); font-weight:500;">70B - 72B</td>
                <td style="padding:11px 16px; font-family:'IBM Plex Mono',monospace; color:var(--accent);">~45 - 48 GB</td>
                <td style="padding:11px 16px; color:var(--text);">2x RTX 3090 / 4090 (Multi-GPU)</td>
                <td style="padding:11px 16px; color:var(--text);">Mac de 64 GB o superior</td>
                <td style="padding:11px 16px; color:var(--dim);">Llama-3.3 70B / DeepSeek-V3 (cuantizado)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Conectar tu código -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; align-items:center; gap:10px; padding-bottom:12px; border-bottom:1px solid var(--border); margin-bottom:18px;">
        <span style="font-size:16px; font-weight:600; color:var(--head);">Conectar tu código (API OpenAI-compatible)</span>
        <span style="font-size:12px; color:var(--dim);">Reutiliza tus SDKs cambiando solo el baseURL y API key</span>
      </div>

      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; overflow:hidden;">
        <!-- Tabs Header -->
        <div id="code-tabs-header" style="display:flex; background:var(--panel2); border-bottom:1px solid var(--border); padding:0 12px;">
          <button class="dbtn code-tab-btn active" data-lang="python" style="font-family:inherit; font-size:13px; color:var(--head); background:transparent; border:none; padding:12px 18px; border-bottom:2px solid var(--accent); cursor:pointer; font-weight:600;">Python</button>
          <button class="dbtn code-tab-btn" data-lang="typescript" style="font-family:inherit; font-size:13px; color:var(--text); background:transparent; border:none; padding:12px 18px; border-bottom:2px solid transparent; cursor:pointer;">TypeScript / Node</button>
          <button class="dbtn code-tab-btn" data-lang="csharp" style="font-family:inherit; font-size:13px; color:var(--text); background:transparent; border:none; padding:12px 18px; border-bottom:2px solid transparent; cursor:pointer;">C# / .NET</button>
        </div>
        <!-- Tabs Content -->
        <div id="code-tabs-content" style="padding:16px;">
          <!-- Python Panel -->
          <div id="code-panel-python" class="code-tab-panel">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:9px;">
              <span style="font-size:11px; font-family:'IBM Plex Mono',monospace; color:var(--dim);">SDK oficial: pip install openai</span>
              <button class="dbtn copy-snippet-btn" data-snippet={snPy} style="margin-left:auto; font-family:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Copiar código</button>
            </div>
            <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-python">{snPy}</code></pre>
          </div>
          <!-- TypeScript Panel -->
          <div id="code-panel-typescript" class="code-tab-panel hidden">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:9px;">
              <span style="font-size:11px; font-family:'IBM Plex Mono',monospace; color:var(--dim);">SDK oficial: npm install openai</span>
              <button class="dbtn copy-snippet-btn" data-snippet={snTs} style="margin-left:auto; font-family:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Copiar código</button>
            </div>
            <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-typescript">{snTs}</code></pre>
          </div>
          <!-- C# Panel -->
          <div id="code-panel-csharp" class="code-tab-panel hidden">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:9px;">
              <span style="font-size:11px; font-family:'IBM Plex Mono',monospace; color:var(--dim);">SDK oficial: dotnet add package OpenAI / System.ClientModel</span>
              <button class="dbtn copy-snippet-btn" data-snippet={snCs} style="margin-left:auto; font-family:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Copiar código</button>
            </div>
            <pre style="margin:0; background:var(--bg); border:1px solid var(--border);"><code class="language-csharp">{snCs}</code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- IDEs y Agentes -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; align-items:center; gap:10px; padding-bottom:12px; border-bottom:1px solid var(--border); margin-bottom:18px;">
        <span style="font-size:16px; font-weight:600; color:var(--head);">Configuración en IDEs y Agentes</span>
        <span style="font-size:12px; color:var(--dim);">Conecta tu modelo local a herramientas de desarrollo</span>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:14px;">
        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:18px;">
          <h3 style="margin:0 0 10px; font-size:15px; font-weight:600; color:var(--head);">OpenCode (Agente de Terminal)</h3>
          <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 12px;">Para configurar el agente de terminal OpenCode con tu modelo local de Ollama, declara un proveedor local compatible en su configuración:</p>
          <pre style="margin:0 0 12px; background:var(--bg); border:1px solid var(--border); font-size:12px;"><code class="language-json">{snOpenCode}</code></pre>
        </div>

        <div class="dcard" style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:18px; display:flex; flex-direction:column; justify-content:space-between;">
          <div>
            <h3 style="margin:0 0 10px; font-size:15px; font-weight:600; color:var(--head);">Extensiones en IDE (Cline, Continue, Roo Code)</h3>
            <p style="font-size:13px; color:var(--dim); line-height:1.5; margin:0 0 12px;">
              Las extensiones de desarrollo modernas facilitan enormemente el uso de proveedores locales en su barra de configuración:
            </p>
            <ul style="padding-left:18px; margin:0; color:var(--dim); font-size:13px; line-height:1.5;">
              <li style="margin-bottom:6px;"><b style="color:var(--head);">Continue:</b> En tu archivo <code>config.json</code>, añade un bloque en <code>"models"</code> con el proveedor <code>"ollama"</code> y el nombre del modelo.</li>
              <li style="margin-bottom:6px;"><b style="color:var(--head);">Cline / Roo Code:</b> Selecciona "OpenAI Compatible" como proveedor, ingresa <code>http://localhost:11434/v1</code> en Base URL y escribe el nombre del modelo.</li>
            </ul>
          </div>
          <div style="font-size:12px; color:var(--accent2); background:var(--panel2); border-radius:6px; padding:8px 10px; border-left:2px solid var(--accent2); margin-top:8px;">
            Ollama también se puede configurar de forma directa seleccionando el driver nativo de Ollama en los selectores.
          </div>
        </div>
      </div>
    </div>

    <!-- Catálogo de Modelos Open-Weight locales -->
    <div style="margin-bottom:28px;">
      <div style="display:flex; align-items:center; gap:10px; padding-bottom:12px; border-bottom:1px solid var(--border); margin-bottom:18px;">
        <span style="font-size:16px; font-weight:600; color:var(--head);">Catálogo de Modelos Open-Weight</span>
        <span style="font-size:12px; color:var(--dim);">Modelos open-weight disponibles en este catálogo para ejecutar localmente</span>
      </div>

      <!-- Buscador -->
      <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
        <div style="flex:1; min-width:220px; max-width:480px; display:flex; align-items:center; gap:9px; background:var(--panel2); border:1px solid var(--border2); border-radius:8px; padding:8px 13px;">
          <span style="color:var(--dim);">⌕</span>
          <input id="models-search" placeholder="Filtrar modelos locales..." spellcheck="false" autocomplete="off" style="flex:1; background:transparent; border:none; outline:none; color:var(--text); font-family:inherit; font-size:13.5px;" />
        </div>
        <span id="models-result-label" style="font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--dim);">{openWeight.length} / {openWeight.length}</span>
      </div>

      <div id="models-empty" class="hidden" style="margin-top:20px; border:1px dashed var(--border2); border-radius:12px; padding:40px; text-align:center; color:var(--dim);">Sin resultados para este filtro.</div>

      <div id="models-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:14px;">
        {openWeight.map((m) => {
          const c = companies[m.company] || { name: m.company, accent: '#888888', origin: m.origin };
          return (
            <div
              class="dcard model-local-card"
              data-id={m.id}
              data-name={m.displayName.toLowerCase()}
              data-company={m.company.toLowerCase()}
              data-notes={(m.notes ?? '').toLowerCase()}
              style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; cursor:pointer;"
            >
              <div style="display:flex; align-items:center; gap:8px;">
                <span style={`width:8px; height:8px; border-radius:50%; background:${c.accent};`}></span>
                <span style="font-size:11px; letter-spacing:.5px; text-transform:uppercase; color:var(--dim);">{c.name}</span>
                {m.license && <span style="margin-left:auto; font-size:10px; color:var(--dim); background:var(--panel2); border-radius:5px; padding:2px 7px;">{m.license}</span>}
              </div>
              <h3 style="margin:10px 0 4px; font-size:16px; font-weight:600; color:var(--head);">{m.displayName}</h3>
              <div style="font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--accent); min-height:15px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{m.apiModelString || '—'}</div>
              
              <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; border-top:1px solid var(--border); padding-top:10px;">
                <div>
                  <span style="font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.3px; display:block;">Tamaño</span>
                  <span style="font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--head); font-weight:600;">{m.parameters ? `${m.parameters}B` : '—'}</span>
                </div>
                <div>
                  <span style="font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.3px; display:block;">Contexto</span>
                  <span style="font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--head); font-weight:600;">{fmtCtx(m.context)}</span>
                </div>
              </div>

              <div style="display:flex; gap:7px; margin-top:14px;">
                <button class="dbtn" data-action="model-detail" data-id={m.id} style="flex:1; font-family:inherit; font-size:12px; padding:7px; border-radius:7px; border:none; background:var(--accent); color:#fff; font-weight:500;">Ver detalle</button>
                {m.playgroundUrl && <a class="dbtn" href={m.playgroundUrl} target="_blank" rel="noopener" style="font-family:inherit; font-size:12px; padding:7px 10px; border-radius:7px; border:1px solid var(--border2); background:var(--panel2); color:var(--text); text-decoration:none; text-align:center;">Probar ↗</a>}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </main>

  <!-- detail drawer -->
  <div id="models-detail-drawer" class="hidden" style="position:fixed; inset:0; z-index:60; background:var(--overlay-bg); display:flex; justify-content:flex-end;">
    <div class="dsh-scroll" id="models-detail-panel" style="width:min(580px,100%); height:100%; overflow-y:auto; background:var(--panel); border-left:1px solid var(--accent); animation:dshslide var(--trans-slow);">
      <div id="models-detail-body"></div>
    </div>
  </div>

  <div style="margin-top: 40px; margin-bottom: 20px;">
    <div class="wrap"><a href="./index.html" class="dlink">← Volver al catálogo</a></div>
  </div>

  <!-- Datos serializados en JSON para el script cliente -->
  <script type="application/json" id="models-data" is:inline set:html={JSON.stringify({
    models: openWeight.map((m) => ({
      id: m.id,
      displayName: m.displayName,
      company: m.company,
      companyName: (companies[m.company] || { name: m.company }).name,
      accent: (companies[m.company] || { accent: '#888' }).accent,
      context: m.context,
      apiModelString: m.apiModelString || '—',
      license: m.license || 'open-weight',
      notes: m.notes || '',
      modalities: m.modalities.join(' · '),
      playgroundUrl: m.playgroundUrl || null,
      docsUrl: m.docsUrl || null,
      videos: m.videos || [],
      examples: m.examples || [],
      releaseDate: m.releaseDate || null,
      popularity: m.popularity ?? 0,
      parameters: m.parameters || null,
    }))
  })}>
  </script>

  <script>
    // 1. Inicialización de datos
    const dataEl = document.getElementById('models-data');
    const DATA = dataEl ? JSON.parse(dataEl.textContent || '{}') : { models: [] };
    const byId = Object.fromEntries(DATA.models.map((m: any) => [m.id, m]));
    const TOTAL = DATA.models.length;

    const esc = (s: any) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const fmtDate = (s: any) => {
      if (!s) return '—';
      const [y, m] = s.split('-');
      const mes = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][parseInt(m, 10) - 1] || '';
      return mes ? `${mes} ${y}` : y;
    };
    const fmtCtx = (n: any) => (n == null ? '—' : n >= 1000000 ? `${n / 1000000}M` : `${Math.round(n / 1000)}K`);

    // Highlight existing blocks on load
    const highlightOnLoad = () => {
      const hjs = (window as any).hljs;
      if (hjs) {
        document.querySelectorAll('pre code').forEach((b) => hjs.highlightElement(b));
      } else {
        window.addEventListener('load', () => {
          const hjsLater = (window as any).hljs;
          if (hjsLater) {
            document.querySelectorAll('pre code').forEach((b) => hjsLater.highlightElement(b));
          }
        });
      }
    };
    highlightOnLoad();

    // 2. Colapsables de Runtimes
    const toggleBtns = document.querySelectorAll('.runtime-toggle-btn');
    toggleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target || '';
        const panel = document.getElementById(targetId);
        if (!panel) return;
        
        const isHidden = panel.classList.contains('hidden');
        
        // Ocultar todos los bloques
        document.querySelectorAll('.runtime-code-panel').forEach((p) => p.classList.add('hidden'));
        document.querySelectorAll('.runtime-toggle-btn').forEach((b) => b.textContent = 'Ver comandos de inicio');
        
        // Mostrar/Ocultar el seleccionado
        if (isHidden) {
          panel.classList.remove('hidden');
          btn.textContent = 'Ocultar comandos';
        }
      });
    });

    // 3. Pestañas de Código (Tabs)
    const tabBtns = document.querySelectorAll('.code-tab-btn');
    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = (btn as HTMLElement).dataset.lang || '';
        
        // Cambiar estilos de los botones de pestañas
        tabBtns.forEach((b) => {
          const active = (b as HTMLElement).dataset.lang === lang;
          b.classList.toggle('active', active);
          (b as HTMLElement).style.borderBottomColor = active ? 'var(--accent)' : 'transparent';
          (b as HTMLElement).style.color = active ? 'var(--head)' : 'var(--text)';
          (b as HTMLElement).style.fontWeight = active ? '600' : '400';
        });
        
        // Mostrar panel correspondiente
        document.querySelectorAll('.code-tab-panel').forEach((p) => {
          p.classList.toggle('hidden', !p.id.endsWith(lang));
        });
      });
    });

    // 4. Copiar Snippets
    document.querySelectorAll('.copy-snippet-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = (btn as HTMLElement).dataset.snippet || '';
        navigator.clipboard.writeText(text).then(() => {
          const origText = btn.textContent;
          btn.textContent = '✓ Copiado';
          setTimeout(() => btn.textContent = origText, 1600);
        });
      });
    });

    // 5. Filtrado del catálogo de modelos
    let q = '';
    const searchInput = document.getElementById('models-search') as HTMLInputElement | null;
    const resultLabel = document.getElementById('models-result-label');
    const emptyEl = document.getElementById('models-empty');

    function matches(el: HTMLElement) {
      const hay = `${el.dataset.name || ''} ${el.dataset.company || ''} ${el.dataset.notes || ''}`;
      return !q || hay.includes(q);
    }

    function applyFilters() {
      let shown = 0;
      document.querySelectorAll('.model-local-card').forEach((el) => {
        const visible = matches(el as HTMLElement);
        el.classList.toggle('hidden', !visible);
        if (visible) shown++;
      });
      if (resultLabel) resultLabel.textContent = `${shown} / ${TOTAL}`;
      if (emptyEl) emptyEl.classList.toggle('hidden', shown > 0);
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        q = (e.target as HTMLInputElement).value.toLowerCase().trim();
        applyFilters();
      });
    }

    // 6. Panel de Detalle (Detail Drawer)
    const drawer = document.getElementById('models-detail-drawer');
    const drawerBody = document.getElementById('models-detail-body');

    function box(label: string, value: string, color: string) {
      return `<div style="background:var(--panel2); border-radius:10px; padding:13px;"><div style="font-size:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim);">${label}</div><div style="font-family:'IBM Plex Mono',monospace; font-size:19px; color:${color}; margin-top:4px;">${value}</div></div>`;
    }
    function boxText(label: string, value: string) {
      return `<div style="background:var(--panel2); border-radius:10px; padding:13px;"><div style="font-size:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim);">${label}</div><div style="font-size:14px; color:var(--head); margin-top:6px;">${esc(value)}</div></div>`;
    }

    function openModelDetail(id: string) {
      const m = byId[id]; if (!m) return;
      const code = m.examples && m.examples[0] ? m.examples[0] : null;

      let html = `
        <div style="position:sticky; top:0; background:var(--panel); border-bottom:1px solid var(--border); padding:13px 22px; display:flex; align-items:center; gap:10px; z-index:10;">
          <span style="width:9px;height:9px;border-radius:50%;background:${esc(m.accent)};"></span>
          <span style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">${esc(m.companyName)}</span>
          <span style="font-size:11px; font-weight:600; color:var(--pos); background:var(--panel2); border-radius:5px; padding:2px 8px; margin-left:6px;">modelo open-weight</span>
          <button class="dbtn" id="model-detail-close" style="margin-left:auto; background:var(--panel2); color:var(--text); border:1px solid var(--border2); padding:5px 12px; font-family:inherit; font-size:12px; border-radius:8px;">Cerrar ✕</button>
        </div>
        <div style="padding:22px 24px 50px;">
          <h2 style="margin:0; font-size:27px; font-weight:600; color:var(--head); letter-spacing:-.4px;">${esc(m.displayName)}</h2>
          <div style="font-size:13px; color:var(--dim); margin-top:4px;">API string: <code>${esc(m.apiModelString)}</code></div>
          <p style="margin:14px 0 0; font-size:14.5px; color:var(--text); line-height:1.55;">${esc(m.notes)}</p>
          
          <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:20px;">
            ${box('Parámetros', m.parameters ? `${m.parameters}B` : '—', 'var(--accent)')}
            ${box('Contexto', fmtCtx(m.context), 'var(--warn)')}
            ${box('Popularidad', m.popularity + '/100', 'var(--accent2)')}
            ${boxText('Licencia', m.license)}
            ${boxText('Modalidades', m.modalities)}
            ${boxText('Lanzamiento', fmtDate(m.releaseDate))}
          </div>`;

      if (code) {
        html += `<div style="margin-top:24px;">
          <div style="display:flex; align-items:center; gap:9px; margin-bottom:9px;">
            <span style="font-size:13px; font-weight:600; color:var(--head);">${esc(code.title || 'Cómo empezar')}</span>
            <span style="font-size:10.5px; color:var(--accent); background:var(--panel2); border-radius:5px; padding:2px 8px;">${esc(code.lang)}</span>
            <button class="dbtn" id="model-copy-code" style="margin-left:auto; font-family:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Copiar</button>
          </div>
          <pre class="dsh-scroll" style="margin:0; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:15px; overflow-x:auto; font-family:'IBM Plex Mono',monospace; font-size:12px; line-height:1.6; color:var(--text);"><code>${esc(code.code)}</code></pre>
        </div>`;
      }

      if (m.videos && m.videos.length) {
        html += `<div style="margin-top:24px;">
          <div style="font-size:13px; font-weight:600; color:var(--head); margin-bottom:9px;">Vídeos de referencia</div>
          <div style="display:flex; flex-direction:column; gap:7px;">`;
        m.videos.forEach((v: any) => {
          html += `<a class="dlink" href="${esc(v.url)}" target="_blank" rel="noopener" style="display:flex; align-items:center; gap:11px; text-decoration:none; color:var(--text); background:var(--panel2); border-radius:9px; padding:10px 13px; font-size:13px;"><span style="color:var(--accent2);">▶</span><span style="flex:1;">${esc(v.title)}</span><span style="color:var(--dim); font-size:11px;">${esc(v.source || '')}</span></a>`;
        });
        html += `</div></div>`;
      }

      html += `<div style="display:flex; gap:9px; margin-top:24px;">
        ${m.playgroundUrl ? `<a href="${esc(m.playgroundUrl)}" target="_blank" rel="noopener" class="dbtn" style="text-decoration:none; flex:1; text-align:center; font-size:13px; padding:11px; border-radius:9px; border:none; background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; font-weight:600;">Playground ↗</a>` : ''}
        ${m.docsUrl ? `<a href="${esc(m.docsUrl)}" target="_blank" rel="noopener" class="dbtn" style="text-decoration:none; flex:1; text-align:center; font-size:13px; padding:11px; border-radius:9px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Docs ↗</a>` : ''}
      </div></div>`;

      if (drawerBody) drawerBody.innerHTML = html;
      if (drawer) drawer.classList.remove('hidden');
      
      const hjs = (window as any).hljs;
      if (hjs && drawerBody) {
        drawerBody.querySelectorAll('pre code').forEach((b) => hjs.highlightElement(b));
      }
      
      const closeBtn = document.getElementById('model-detail-close');
      if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
      
      const copyBtn = document.getElementById('model-copy-code');
      if (copyBtn && code) {
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(code.code).then(() => {
            copyBtn.textContent = '✓ Copiado';
            setTimeout(() => copyBtn.textContent = 'Copiar', 1600);
          });
        });
      }
    }

    function closeDrawer() {
      if (drawer) drawer.classList.add('hidden');
    }

    if (drawer) {
      drawer.addEventListener('click', (e) => {
        if (e.target === drawer) closeDrawer();
      });
    }
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });

    // 7. Delegación de clics
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const det = target.closest('[data-action="model-detail"]');
      if (det) {
        openModelDetail((det as HTMLElement).dataset.id || '');
        return;
      }
      const card = target.closest('.model-local-card');
      if (card && !target.closest('a')) {
        openModelDetail((card as HTMLElement).dataset.id || '');
        return;
      }
    });

    applyFilters();
  </script>
</Layout>

