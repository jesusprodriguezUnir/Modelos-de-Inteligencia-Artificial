---
import Layout from '../layouts/Layout.astro';
import ModelCard from '../components/ModelCard.astro';
import { models, companies, POPULARITY_TIERS, popularityTier } from '../data/models';
import type { Model } from '../data/types';

const catLabels: Record<string, string> = {
  coding: 'Código', reasoning: 'Razonamiento', agentic: 'Agéntico', general: 'General',
  multimodal: 'Multimodal', fast: 'Rápido', budget: 'Económico', tool: 'Herramienta',
};
const originLabels: Record<string, string> = { US: 'EE. UU.', EU: 'Europa', China: 'China', Open: 'Open' };

const onlyModels = models.filter((m) => m.kind === 'model');

const stats = {
  models: onlyModels.length,
  companies: Object.keys(companies).length,
  open: onlyModels.filter((m) => m.openWeight).length,
};

const originChips = ['all', 'US', 'China', 'EU', 'Open'];
const catChips = ['all', 'coding', 'reasoning', 'agentic', 'multimodal', 'fast', 'budget', 'general', 'tool'];

const fmtCtx = (n: number | null) => (n == null ? '—' : n >= 1_000_000 ? `${n / 1_000_000}M` : `${Math.round(n / 1000)}K`);
const fmtPrice = (p: number | null) => (p == null ? '—' : `$${p}`);

// Máximos para escalar las barras métricas.
const mx = {
  in: Math.max(1, ...onlyModels.map((m) => m.pricing.inputPer1M || 0)),
  out: Math.max(1, ...onlyModels.map((m) => m.pricing.outputPer1M || 0)),
  ctx: Math.max(1, ...onlyModels.map((m) => m.context || 0)),
};
const pct = (v: number | null | undefined, max: number) =>
  !v || !max ? '0%' : `${Math.max(4, Math.min(100, (v / max) * 100))}%`;

function decorate(m: Model) {
  const c = companies[m.company] || { name: m.company, accent: '#888888', origin: m.origin };
  const pIn = m.pricing.inputPer1M, pOut = m.pricing.outputPer1M;
  const priceText = (pIn == null && pOut == null) ? 'suscr.' : (`$${pIn}/$${pOut}${m.pricing.approx ? '~' : ''}`);
  const swe = m.benchmarks?.sweBenchPro ?? null;
  const tier = popularityTier(m.popularity);
  return {
    ...m,
    accent: c.accent,
    companyName: c.name,
    kindLabel: m.kind === 'tool' ? 'agente' : 'modelo',
    originLabel: originLabels[m.origin] || m.origin,
    categoryKeys: m.category,
    cats: m.category.slice(0, 3).map((k) => catLabels[k] || k),
    contextText: fmtCtx(m.context),
    priceText,
    priceInText: fmtPrice(pIn) + (m.pricing.approx && pIn != null ? '~' : ''),
    priceOutText: fmtPrice(pOut) + (m.pricing.approx && pOut != null ? '~' : ''),
    openWeight: !!m.openWeight,
    swe,
    sweText: swe ? `${swe}%` : '',
    sweCell: swe ? `${swe}%` : '—',
    barInPct: pct(pIn, mx.in),
    barOutPct: pct(pOut, mx.out),
    barCtxPct: pct(m.context, mx.ctx),
    barSwePct: swe ? `${swe}%` : '0%',
    api: m.apiModelString || '—',
    popularity: m.popularity ?? 0,
    tierKey: tier.key,
    tierLabel: tier.label,
  };
}

const decorated = onlyModels.map(decorate);

// ── KPIs ──────────────────────────────────────────────────────────────────
const withSwe = decorated.filter((m) => m.swe != null);
const bestSwe = [...withSwe].sort((a, b) => (b.swe! - a.swe!))[0];
const withIn = onlyModels.filter((m) => m.pricing.inputPer1M != null && m.pricing.inputPer1M > 0);
const cheap = [...withIn].sort((a, b) => a.pricing.inputPer1M! - b.pricing.inputPer1M!)[0];
const withCtx = onlyModels.filter((m) => m.context);
const bigCtx = [...withCtx].sort((a, b) => b.context! - a.context!)[0];

// ── Distribución por origen ────────────────────────────────────────────────
const oColors: Record<string, string> = { US: 'var(--accent)', China: 'var(--accent2)', EU: 'var(--warn)', Open: 'var(--pos)' };
const total = onlyModels.length || 1;
const originDist = (['US', 'China', 'EU', 'Open'] as const).map((o) => {
  const count = onlyModels.filter((m) => m.origin === o).length;
  return { label: originLabels[o], count, pct: `${(count / total) * 100}%`, color: oColors[o] };
});

// ── Leaderboards / agrupaciones ────────────────────────────────────────────
const topPopularity = [...decorated].sort((a, b) => b.popularity - a.popularity).slice(0, 8);
const maxPop = topPopularity[0]?.popularity || 100;
const leaderboardSwe = [...withSwe].sort((a, b) => (b.swe! - a.swe!)).slice(0, 7);

// Agrupación por empresa (respeta el orden de `companies`, solo modelos).
const companyGroups = Object.keys(companies)
  .map((key) => ({ key, meta: companies[key], items: decorated.filter((m) => m.company === key) }))
  .filter((g) => g.items.length > 0);
const maxCompanyCount = Math.max(...companyGroups.map((g) => g.items.length), 1);

// Agrupación por nivel de popularidad.
const popularityGroups = POPULARITY_TIERS
  .map((t) => ({ tier: t, items: decorated.filter((m) => m.tierKey === t.key).sort((a, b) => b.popularity - a.popularity) }))
  .filter((g) => g.items.length > 0);
---

<Layout title="Catálogo de Modelos de IA para Programación" active="index">
  <main class="wrap" style="padding-top:24px; padding-bottom:150px;">

    <!-- intro -->
    <div style="margin-bottom:18px;">
      <h1 style="margin:0 0 6px; font-size:clamp(24px,3.4vw,34px); font-weight:700; color:var(--head); letter-spacing:-.5px;">Panel de modelos de IA para programar</h1>
      <p style="margin:0; color:var(--dim); font-size:14.5px; max-width:680px;">Precios por millón de tokens, ventana de contexto y SWE-bench de los modelos disponibles a junio de 2026. Confirma siempre el precio oficial antes de presupuestar.</p>
    </div>

    <!-- search -->
    <div style="display:flex; align-items:center; gap:var(--space-4); flex-wrap:wrap; margin-bottom:var(--space-5);">
      <div style="flex:1; min-width:220px; max-width:480px; display:flex; align-items:center; gap:var(--space-3); background:var(--panel2); border:1px solid var(--border2); border-radius:var(--radius-md); padding:var(--space-2) var(--space-3);">
        <span style="color:var(--dim);">⌕</span>
        <input id="search" placeholder="Filtrar modelos, empresas o tecnologías…" spellcheck="false" autocomplete="off" style="flex:1; background:transparent; border:none; outline:none; color:var(--text); font-family:inherit; font-size:var(--fs-base-lg);" />
      </div>
      <span id="result-label" style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-base); color:var(--dim);">{onlyModels.length} / {onlyModels.length}</span>
    </div>

    <!-- KPI strip -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:var(--space-4);">
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-4) var(--space-5);">
        <div style="font-size:var(--fs-xs); letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Catálogo</div>
        <div style="display:flex; align-items:baseline; gap:var(--space-2); margin-top:var(--space-2);"><span style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-4xl); font-weight:600; color:var(--head);">{stats.models}</span><span style="font-size:var(--fs-md); color:var(--dim);">modelos · {stats.open} open-weight</span></div>
        <div style="display:flex; height:7px; border-radius:var(--radius-xs); overflow:hidden; margin-top:var(--space-3); background:var(--panel2);">
          {originDist.map((seg) => <span title={seg.label} style={`width:${seg.pct}; background:${seg.color}; display:block;`}></span>)}
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:var(--space-3); margin-top:var(--space-3);">
          {originDist.map((seg) => (
            <span style="display:inline-flex; align-items:center; gap:var(--space-1); font-size:var(--fs-xs); color:var(--dim);"><span style={`width:8px;height:8px;border-radius:var(--radius-xs);background:${seg.color};`}></span>{seg.label} {seg.count}</span>
          ))}
        </div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-4) var(--space-5);">
        <div style="font-size:var(--fs-xs); letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Mejor SWE-bench Pro</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-4xl); font-weight:600; color:var(--pos); margin-top:var(--space-2);">{bestSwe ? bestSwe.sweText : '—'}</div>
        <div style="font-size:var(--fs-md); color:var(--head); margin-top:var(--space-1);">{bestSwe ? bestSwe.displayName : ''}</div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-4) var(--space-5);">
        <div style="font-size:var(--fs-xs); letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Entrada más barata /1M</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-4xl); font-weight:600; color:var(--accent2); margin-top:var(--space-2);">{cheap ? `$${cheap.pricing.inputPer1M}` : '—'}</div>
        <div style="font-size:var(--fs-md); color:var(--head); margin-top:var(--space-1);">{cheap ? cheap.displayName : ''}</div>
      </div>
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-4) var(--space-5);">
        <div style="font-size:var(--fs-xs); letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">Mayor contexto</div>
        <div style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-4xl); font-weight:600; color:var(--accent); margin-top:var(--space-2);">{bigCtx ? fmtCtx(bigCtx.context) : '—'}</div>
        <div style="font-size:var(--fs-md); color:var(--head); margin-top:var(--space-1);">{bigCtx ? bigCtx.displayName : ''}</div>
      </div>
    </div>

    <!-- featured: leaderboards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:14px; margin-top:14px;">
      <!-- Top por popularidad -->
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:18px 20px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
          <span style="font-size:13px; font-weight:600; color:var(--head); letter-spacing:.2px;">Top por popularidad</span>
          <span style="font-size:11px; color:var(--dim);">uso/adopción estimada</span>
        </div>
        <div style="display:flex; flex-direction:column; gap:9px;">
          {topPopularity.map((m) => (
            <div data-action="detail" data-id={m.id} style="display:flex; align-items:center; gap:12px; cursor:pointer;">
              <span style="width:130px; flex:none; font-size:12.5px; color:var(--head); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><span style={`display:inline-block;width:7px;height:7px;border-radius:50%;background:${m.accent};margin-right:7px;`}></span>{m.displayName}</span>
              <div style="flex:1; height:13px; background:var(--panel2); border-radius:4px; overflow:hidden;"><span style={`display:block; height:100%; width:${(m.popularity / maxPop) * 100}%; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:4px;`}></span></div>
              <span style="width:34px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--accent);">{m.popularity}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Ranking SWE-bench -->
      <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:18px 20px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
          <span style="font-size:13px; font-weight:600; color:var(--head); letter-spacing:.2px;">Ranking SWE-bench Pro</span>
          <span style="font-size:11px; color:var(--dim);">% resueltos · código agéntico</span>
        </div>
        <div style="display:flex; flex-direction:column; gap:9px;">
          {leaderboardSwe.map((m) => (
            <div data-action="detail" data-id={m.id} style="display:flex; align-items:center; gap:12px; cursor:pointer;">
              <span style="width:130px; flex:none; font-size:12.5px; color:var(--head); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><span style={`display:inline-block;width:7px;height:7px;border-radius:50%;background:${m.accent};margin-right:7px;`}></span>{m.displayName}</span>
              <div style="flex:1; height:13px; background:var(--panel2); border-radius:4px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barSwePct}; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:4px;`}></span></div>
              <span style="width:48px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--pos);">{m.sweText}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- featured: empresas (resumen + filtro rápido) -->
    <div style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:18px 20px; margin-top:14px;">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
        <span style="font-size:13px; font-weight:600; color:var(--head); letter-spacing:.2px;">Por empresa</span>
        <span style="font-size:11px; color:var(--dim);">clic para filtrar el catálogo</span>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px;">
        {companyGroups.map((g) => (
          <div class="dbtn" data-company-filter={g.key} style="display:flex; align-items:center; gap:10px; background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:10px 12px;">
            <span style={`width:10px; height:10px; border-radius:50%; background:${g.meta.accent}; flex:none;`}></span>
            <div style="flex:1; min-width:0;">
              <div style="font-size:13px; color:var(--head); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{g.meta.name}</div>
              <div style="height:5px; background:var(--bg); border-radius:3px; overflow:hidden; margin-top:5px;"><span style={`display:block; height:100%; width:${(g.items.length / maxCompanyCount) * 100}%; background:${g.meta.accent}; border-radius:3px;`}></span></div>
            </div>
            <span style="font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--dim); flex:none;">{g.items.length}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- filter pills + view toggle -->
    <div style="display:flex; flex-wrap:wrap; gap:var(--space-2); align-items:center; margin-top:var(--space-6);">
      <div id="origin-chips" style="display:flex; flex-wrap:wrap; gap:var(--space-2);">
        {originChips.map((o) => (
          <button class="dpill" data-origin={o} data-active={o === 'all' ? 'true' : 'false'} style={`font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); border:1px solid ${o === 'all' ? 'var(--accent)' : 'var(--border2)'}; background:${o === 'all' ? 'var(--accent)' : 'transparent'}; color:${o === 'all' ? '#fff' : 'var(--text)'};`}>{o === 'all' ? 'Todos' : (originLabels[o] || o)}</button>
        ))}
      </div>
      <span style="width:1px; height:22px; background:var(--border2); margin:0 var(--space-1);"></span>
      <div id="cat-chips" style="display:flex; flex-wrap:wrap; gap:var(--space-2);">
        {catChips.map((c) => (
          <button class="dpill" data-cat={c} data-active={c === 'all' ? 'true' : 'false'} style={`font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); border:1px solid ${c === 'all' ? 'var(--accent)' : 'var(--border2)'}; background:${c === 'all' ? 'var(--accent)' : 'transparent'}; color:${c === 'all' ? '#fff' : 'var(--text)'};`}>{c === 'all' ? 'Todas' : (catLabels[c] || c)}</button>
        ))}
      </div>
      <div id="view-toggle" style="margin-left:auto; display:flex; gap:0; border:1px solid var(--border2); border-radius:var(--radius-md); overflow:hidden;">
        <button class="dbtn vbtn" data-view="grid" style="font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border:none; background:var(--accent); color:#fff;">▦ Tarjetas</button>
        <button class="dbtn vbtn" data-view="table" style="font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border:none; border-left:1px solid var(--border2); background:transparent; color:var(--text);">≣ Tabla</button>
        <button class="dbtn vbtn" data-view="company" style="font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border:none; border-left:1px solid var(--border2); background:transparent; color:var(--text);">▥ Empresa</button>
        <button class="dbtn vbtn" data-view="popularity" style="font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border:none; border-left:1px solid var(--border2); background:transparent; color:var(--text);">★ Popularidad</button>
      </div>
    </div>

    <!-- empty -->
    <div id="empty" class="hidden" style="margin-top:30px; border:1px dashed var(--border2); border-radius:12px; padding:60px; text-align:center; color:var(--dim);">Sin resultados para este filtro.</div>

    <!-- GRID view -->
    <div id="view-grid" class="view">
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:14px; margin-top:18px;">
        {decorated.map((m) => <ModelCard m={m} />)}
      </div>
    </div>

    <!-- TABLE view -->
    <div id="view-table" class="view hidden">
      <div class="dsh-scroll" style="margin-top:18px; background:var(--panel); border:1px solid var(--border); border-radius:12px; overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; min-width:820px; font-size:13px;">
          <thead>
            <tr style="text-align:left; color:var(--dim);">
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2);">Modelo</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2);">Empresa</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2);">Origen</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2); text-align:right;">In/1M</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2); text-align:right;">Out/1M</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2); text-align:right;">Contexto</th>
              <th style="padding:12px 16px; font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:.6px; border-bottom:1px solid var(--border2); width:150px;">SWE-bench</th>
            </tr>
          </thead>
          <tbody>
            {decorated.map((m) => (
              <tr class="drow" data-id={m.id} data-name={m.displayName.toLowerCase()} data-company={m.company.toLowerCase()} data-api={(m.apiModelString ?? '').toLowerCase()} data-notes={(m.notes ?? '').toLowerCase()} data-origin={m.origin} data-cats={m.categoryKeys.join(' ')} data-kind={m.kind} data-pop={m.popularity} data-tier={m.tierKey} style="border-bottom:1px solid var(--border); cursor:pointer;">
                <td style="padding:11px 16px;"><span style={`display:inline-block; width:8px; height:8px; border-radius:50%; background:${m.accent}; margin-right:9px;`}></span><span style="color:var(--head); font-weight:500;">{m.displayName}</span></td>
                <td style="padding:11px 16px; color:var(--dim);">{m.companyName}</td>
                <td style="padding:11px 16px; color:var(--text);">{m.originLabel}</td>
                <td style="padding:11px 16px; text-align:right; font-family:'IBM Plex Mono',monospace; color:var(--text);">{m.priceInText}</td>
                <td style="padding:11px 16px; text-align:right; font-family:'IBM Plex Mono',monospace; color:var(--text);">{m.priceOutText}</td>
                <td style="padding:11px 16px; text-align:right; font-family:'IBM Plex Mono',monospace; color:var(--text);">{m.contextText}</td>
                <td style="padding:11px 16px;"><div style="display:flex; align-items:center; gap:8px;"><div style="flex:1; height:7px; background:var(--panel2); border-radius:3px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barSwePct}; background:var(--pos); border-radius:3px;`}></span></div><span style="font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--pos); width:38px; text-align:right;">{m.sweCell}</span></div></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- COMPANY view (drill-down de 2 pasos: empresa → modelos) -->
    <div id="view-company" class="view hidden">
      <!-- Paso 1: selector de empresa -->
      <div id="company-picker">
        <div style="display:flex; align-items:center; gap:10px; margin:22px 0 14px;">
          <span style="font-size:16px; font-weight:600; color:var(--head);">Elige una empresa</span>
          <span style="font-size:12px; color:var(--dim);">clic para ver sus modelos</span>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px;">
          {companyGroups.map((g) => (
            <button type="button" class="dbtn" data-company-pick={g.key} style="text-align:left; display:flex; align-items:center; gap:11px; background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:14px 15px; cursor:pointer; font-family:inherit;">
              <span style={`width:11px; height:11px; border-radius:50%; background:${g.meta.accent}; flex:none;`}></span>
              <div style="flex:1; min-width:0;">
                <div style="display:flex; align-items:center; gap:7px;">
                  <span style="font-size:14px; font-weight:600; color:var(--head); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{g.meta.name}</span>
                  <span style="font-size:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim); border:1px solid var(--border2); border-radius:5px; padding:1px 6px; flex:none;">{originLabels[g.meta.origin] || g.meta.origin}</span>
                </div>
                <div style="height:5px; background:var(--bg); border-radius:3px; overflow:hidden; margin-top:7px;"><span style={`display:block; height:100%; width:${(g.items.length / maxCompanyCount) * 100}%; background:${g.meta.accent}; border-radius:3px;`}></span></div>
              </div>
              <span style="font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--dim); flex:none;">{g.items.length}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Paso 2: modelos de la empresa seleccionada -->
      <div id="company-models" class="hidden">
        <div style="display:flex; align-items:center; gap:12px; margin:22px 0 14px; flex-wrap:wrap;">
          <button type="button" class="dbtn" id="company-back" style="font-family:inherit; font-size:12.5px; padding:7px 14px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">← Empresas</button>
          <span id="company-head-dot" style="width:11px; height:11px; border-radius:50%; background:var(--accent);"></span>
          <span id="company-head-name" style="font-size:16px; font-weight:600; color:var(--head);"></span>
          <span id="company-head-origin" style="font-size:11px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim); border:1px solid var(--border2); border-radius:5px; padding:1px 7px;"></span>
          <span id="company-head-blurb" style="font-size:12.5px; color:var(--dim); flex:1; min-width:0;"></span>
        </div>
        {companyGroups.map((g) => (
          <div class="group" data-group={g.key} style="margin-top:14px;">
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:14px;">
              {g.items.map((m) => <ModelCard m={m} />)}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- POPULARITY view -->
    <div id="view-popularity" class="view hidden">
      {popularityGroups.map((g) => (
        <div class="group" data-group={g.tier.key} style="margin-top:26px;">
          <div style="display:flex; align-items:center; gap:10px; padding-bottom:10px; border-bottom:1px solid var(--border); margin-bottom:14px;">
            <span style="font-size:16px; font-weight:600; color:var(--head);">{g.tier.label}</span>
            <span style="font-size:11px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim);">{g.tier.key === 'top' ? '≥ 70' : g.tier.key === 'popular' ? '40–69' : '< 40'} de popularidad</span>
            <span style="font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--dim); margin-left:auto;">{g.items.length}</span>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:14px;">
            {g.items.map((m) => <ModelCard m={m} />)}
          </div>
        </div>
      ))}
    </div>
  </main>

  <!-- compare tray -->
  <div id="compare-tray" class="hidden" style="position:fixed; left:0; right:0; bottom:0; z-index:45; background:var(--panel); border-top:1px solid var(--accent); padding:12px 22px;">
    <div style="max-width:1280px; margin:0 auto; display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
      <span style="font-size:12px; color:var(--accent); font-weight:600;">Comparar <span id="tray-count">0</span>/4</span>
      <div id="tray-chips" style="display:flex; gap:7px; flex-wrap:wrap; flex:1;"></div>
      <button class="dbtn" id="tray-clear" style="font-family:inherit; font-size:12px; padding:7px 13px; border-radius:8px; border:1px solid var(--border2); background:transparent; color:var(--dim);">Vaciar</button>
      <button class="dbtn" id="tray-open" style="font-family:inherit; font-size:12.5px; padding:7px 18px; border-radius:8px; border:none; background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; font-weight:600;">Comparar →</button>
    </div>
  </div>

  <!-- detail drawer -->
  <div id="detail-drawer" class="hidden" style="position:fixed; inset:0; z-index:60; background:var(--overlay-bg); display:flex; justify-content:flex-end;">
    <div class="dsh-scroll" id="detail-panel" style="width:min(580px,100%); height:100%; overflow-y:auto; background:var(--panel); border-left:1px solid var(--accent); animation:dshslide var(--trans-slow);">
      <div id="detail-body"></div>
    </div>
  </div>

  <!-- compare overlay -->
  <div id="compare-overlay" class="hidden" style="position:fixed; inset:0; z-index:65; background:var(--overlay-bg); display:flex; align-items:center; justify-content:center; padding:var(--space-6);">
    <div class="dsh-scroll" id="compare-panel" style="width:min(1120px,100%); max-height:88vh; overflow:auto; background:var(--panel); border:1px solid var(--accent); border-radius:14px;">
      <div style="position:sticky; top:0; background:var(--panel); border-bottom:1px solid var(--border); padding:var(--space-4) var(--space-5); display:flex; align-items:center; gap:var(--space-3);">
        <span style="font-size:var(--fs-xl); font-weight:600; color:var(--head);">Comparativa lado a lado</span>
        <button class="dbtn" id="compare-close" style="margin-left:auto; background:var(--panel2); color:var(--text); border:1px solid var(--border2); padding:var(--space-1) var(--space-3); font-family:inherit; font-size:var(--fs-sm); border-radius:var(--radius-md);">Cerrar ✕</button>
      </div>
      <div id="compare-body" style="padding:var(--space-5); display:grid; gap:var(--space-4); grid-template-columns:repeat(auto-fit,minmax(230px,1fr));"></div>
    </div>
  </div>

  <script type="application/json" id="model-data" is:inline set:html={JSON.stringify({ models: onlyModels, companies, catLabels, originLabels })}></script>

  <script>
    const DATA = JSON.parse(document.getElementById('model-data').textContent);
    const byId = Object.fromEntries(DATA.models.map((m) => [m.id, m]));
    const C = DATA.companies, CAT = DATA.catLabels, ORI = DATA.originLabels;
    const TOTAL = DATA.models.length;

    const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const fmtCtx = (n) => n == null ? '—' : n >= 1e6 ? `${n / 1e6}M` : `${Math.round(n / 1000)}K`;
    const fmtPrice = (p) => p == null ? '—' : `$${p}`;
    const fmtDate = (s) => {
      if (!s) return '—';
      const [y, m] = s.split('-');
      const mes = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][parseInt(m, 10) - 1] || '';
      return mes ? `${mes} ${y}` : y;
    };

    function decorate(m) {
      const c = C[m.company] || { name: m.company, accent: '#888888' };
      const pIn = m.pricing.inputPer1M, pOut = m.pricing.outputPer1M;
      const swe = (m.benchmarks && m.benchmarks.sweBenchPro) || null;
      return {
        raw: m, id: m.id, displayName: m.displayName, company: c.name, accent: c.accent,
        api: m.apiModelString || '—', kindLabel: m.kind === 'tool' ? 'agente' : 'modelo',
        originLabel: ORI[m.origin] || m.origin,
        cats: m.category.slice(0, 3).map((k) => CAT[k] || k),
        contextText: fmtCtx(m.context),
        priceInText: fmtPrice(pIn) + (m.pricing.approx && pIn != null ? '~' : ''),
        priceOutText: fmtPrice(pOut) + (m.pricing.approx && pOut != null ? '~' : ''),
        priceNote: m.pricing.note || null,
        openWeight: !!m.openWeight,
        sweCell: swe ? (swe + '%') : '—',
        notes: m.notes || '', modalText: m.modalities.join(' · '),
        licenseText: m.license || (m.openWeight ? 'open-weight' : 'propietario'),
        releaseText: fmtDate(m.releaseDate),
        playgroundUrl: m.playgroundUrl || null, docsUrl: m.docsUrl || null,
        videos: m.videos || [], hasVideos: !!(m.videos && m.videos.length),
        hasCode: !!(m.examples && m.examples.length),
        code: (m.examples && m.examples[0]) ? m.examples[0].code : '',
        codeLang: (m.examples && m.examples[0]) ? m.examples[0].lang : '',
        codeTitle: (m.examples && m.examples[0]) ? m.examples[0].title : 'Cómo empezar',
        popularity: m.popularity ?? 0,
      };
    }

    // ── Filtros y vistas ───────────────────────────────────────────────
    let q = '', origin = 'all', cat = 'all', view = 'grid';
    let companyPick = null; // clave de empresa seleccionada en la vista Empresa (null = paso 1)
    const searchInput = document.getElementById('search');
    const resultLabel = document.getElementById('result-label');
    const empty = document.getElementById('empty');
    const containers = {
      grid: document.getElementById('view-grid'),
      table: document.getElementById('view-table'),
      company: document.getElementById('view-company'),
      popularity: document.getElementById('view-popularity'),
    };

    function matches(el) {
      const hay = `${el.dataset.name || ''} ${el.dataset.company || ''} ${el.dataset.api || ''} ${el.dataset.notes || ''}`;
      if (q && !hay.includes(q)) return false;
      if (origin !== 'all' && el.dataset.origin !== origin) return false;
      if (cat !== 'all' && !(el.dataset.cats || '').split(' ').includes(cat)) return false;
      return true;
    }

    function applyFilters() {
      document.querySelectorAll('.dcard, .drow').forEach((el) => el.classList.toggle('hidden', !matches(el)));
      document.querySelectorAll('.group').forEach((g) => {
        // En la vista Empresa solo se muestra el grupo de la empresa seleccionada (paso 2).
        const inCompanyStep1 = view === 'company' && companyPick == null;
        const wrongCompany = view === 'company' && companyPick != null && g.dataset.group !== companyPick;
        const noMatches = g.querySelectorAll('.dcard:not(.hidden)').length === 0;
        g.classList.toggle('hidden', inCompanyStep1 || wrongCompany || noMatches);
      });
      // En el paso 1 de Empresa no aplica el conteo ni el estado "sin resultados".
      if (view === 'company' && companyPick == null) {
        resultLabel.textContent = `${TOTAL} / ${TOTAL}`;
        empty.classList.add('hidden');
        containers[view].classList.remove('hidden');
        return;
      }
      const cont = containers[view];
      const sel = view === 'table' ? '.drow:not(.hidden)' : '.dcard:not(.hidden)';
      const scope = view === 'company' && companyPick != null
        ? cont.querySelector(`.group[data-group="${companyPick}"]`)
        : cont;
      const shown = scope ? scope.querySelectorAll(sel).length : 0;
      resultLabel.textContent = `${shown} / ${TOTAL}`;
      if (shown === 0) { empty.classList.remove('hidden'); cont.classList.add('hidden'); }
      else { empty.classList.add('hidden'); cont.classList.remove('hidden'); }
    }

    // ── Drill-down de empresa (paso 1 ↔ paso 2) ────────────────────────
    const companyPicker = document.getElementById('company-picker');
    const companyModels = document.getElementById('company-models');
    function enterCompany(key) {
      companyPick = key;
      const c = C[key] || { name: key, accent: '#888888', origin: '', blurb: '' };
      document.getElementById('company-head-dot').style.background = c.accent;
      document.getElementById('company-head-name').textContent = c.name;
      document.getElementById('company-head-origin').textContent = ORI[c.origin] || c.origin || '';
      document.getElementById('company-head-blurb').textContent = c.blurb || '';
      companyPicker.classList.add('hidden');
      companyModels.classList.remove('hidden');
      applyFilters();
      document.getElementById('search').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function exitCompany() {
      companyPick = null;
      companyModels.classList.add('hidden');
      companyPicker.classList.remove('hidden');
      applyFilters();
    }

    function setView(v) {
      view = v;
      // La vista Empresa siempre arranca en el paso 1 (selector de empresa).
      companyPick = null;
      if (companyModels && companyPicker) {
        companyModels.classList.add('hidden');
        companyPicker.classList.remove('hidden');
      }
      Object.entries(containers).forEach(([k, el]) => el.classList.toggle('hidden', k !== v));
      document.querySelectorAll('.vbtn').forEach((b) => {
        const active = b.dataset.view === v;
        b.style.background = active ? 'var(--accent)' : 'transparent';
        b.style.color = active ? '#fff' : 'var(--text)';
      });
      applyFilters();
    }

    function setPills(group, value, attr) {
      group.querySelectorAll('.dpill').forEach((b) => {
        const active = b.dataset[attr] === value;
        b.style.background = active ? 'var(--accent)' : 'transparent';
        b.style.color = active ? '#fff' : 'var(--text)';
        b.style.borderColor = active ? 'var(--accent)' : 'var(--border2)';
        b.dataset.active = active ? 'true' : 'false';
      });
    }

    searchInput.addEventListener('input', (e) => { q = e.target.value.toLowerCase().trim(); applyFilters(); });
    document.getElementById('origin-chips').addEventListener('click', (e) => {
      const b = e.target.closest('.dpill'); if (!b) return;
      origin = b.dataset.origin; setPills(e.currentTarget, origin, 'origin'); applyFilters();
    });
    document.getElementById('cat-chips').addEventListener('click', (e) => {
      const b = e.target.closest('.dpill'); if (!b) return;
      cat = b.dataset.cat; setPills(e.currentTarget, cat, 'cat'); applyFilters();
    });
    document.getElementById('view-toggle').addEventListener('click', (e) => {
      const b = e.target.closest('.vbtn'); if (!b) return;
      setView(b.dataset.view);
    });

    function filterByCompany(key) {
      q = key.toLowerCase();
      searchInput.value = key;
      setView('grid');
      document.getElementById('search').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ── Detalle lateral ────────────────────────────────────────────────
    const detailDrawer = document.getElementById('detail-drawer');
    const detailBody = document.getElementById('detail-body');

    function box(label, value, color) {
      return `<div style="background:var(--panel2); border-radius:10px; padding:13px;"><div style="font-size:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim);">${label}</div><div style="font-family:'IBM Plex Mono',monospace; font-size:19px; color:${color}; margin-top:4px;">${value}</div></div>`;
    }
    function boxText(label, value) {
      return `<div style="background:var(--panel2); border-radius:10px; padding:13px;"><div style="font-size:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--dim);">${label}</div><div style="font-size:14px; color:var(--head); margin-top:6px;">${esc(value)}</div></div>`;
    }

    function openDetail(id) {
      const d = decorate(byId[id]); if (!d) return;
      let html = `
        <div style="position:sticky; top:0; background:var(--panel); border-bottom:1px solid var(--border); padding:13px 22px; display:flex; align-items:center; gap:10px;">
          <span style="width:9px;height:9px;border-radius:50%;background:${d.accent};"></span>
          <span style="font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--dim);">${esc(d.company)}</span>
          <button class="dbtn" id="detail-close" style="margin-left:auto; background:var(--panel2); color:var(--text); border:1px solid var(--border2); padding:5px 12px; font-family:inherit; font-size:12px; border-radius:8px;">Cerrar ✕</button>
        </div>
        <div style="padding:22px 24px 50px;">
          <h2 style="margin:0; font-size:27px; font-weight:600; color:var(--head); letter-spacing:-.4px;">${esc(d.displayName)}</h2>
          <div style="font-family:'IBM Plex Mono',monospace; font-size:13px; color:var(--accent); margin-top:3px; min-height:17px;">${esc(d.api)}</div>
          <p style="margin:14px 0 0; font-size:14.5px; color:var(--text); line-height:1.55;">${esc(d.notes)}</p>
          <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:16px;">
            <span style="font-size:11px; color:var(--text); background:var(--panel2); border-radius:6px; padding:3px 10px;">${esc(d.originLabel)}</span>
            ${d.cats.map((c) => `<span style="font-size:11px; color:var(--dim); background:var(--panel2); border-radius:6px; padding:3px 10px;">${esc(c)}</span>`).join('')}
            ${d.openWeight ? `<span style="font-size:11px; color:var(--pos); border:1px solid var(--pos); border-radius:6px; padding:2px 9px;">open-weight</span>` : ''}
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:20px;">
            ${box('In /1M', esc(d.priceInText), 'var(--accent2)')}
            ${box('Out /1M', esc(d.priceOutText), 'var(--accent)')}
            ${box('Contexto', esc(d.contextText), 'var(--warn)')}
            ${box('SWE-bench', esc(d.sweCell), 'var(--pos)')}
            ${boxText('Licencia', d.licenseText)}
            ${boxText('Lanzamiento', d.releaseText)}
          </div>
          <div style="margin-top:12px; font-size:12.5px; color:var(--dim);">Modalidades: <span style="color:var(--text);">${esc(d.modalText)}</span></div>`;

      if (d.priceNote) html += `<div style="margin-top:12px; font-size:12.5px; color:var(--dim); background:var(--panel2); border-radius:8px; padding:11px 13px;">${esc(d.priceNote)}</div>`;

      if (d.hasCode) {
        html += `<div style="margin-top:24px;">
          <div style="display:flex; align-items:center; gap:9px; margin-bottom:9px;">
            <span style="font-size:13px; font-weight:600; color:var(--head);">${esc(d.codeTitle)}</span>
            <span style="font-size:10.5px; color:var(--accent); background:var(--panel2); border-radius:5px; padding:2px 8px;">${esc(d.codeLang)}</span>
            <button class="dbtn" id="copy-code" style="margin-left:auto; font-family:inherit; font-size:11.5px; padding:5px 12px; border-radius:8px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Copiar</button>
          </div>
          <pre class="dsh-scroll" style="margin:0; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:15px; overflow-x:auto; font-family:'IBM Plex Mono',monospace; font-size:12px; line-height:1.6; color:var(--text);"><code>${esc(d.code)}</code></pre>
        </div>`;
      }

      if (d.hasVideos) {
        html += `<div style="margin-top:24px;">
          <div style="font-size:13px; font-weight:600; color:var(--head); margin-bottom:9px;">Vídeos de referencia</div>
          <div style="display:flex; flex-direction:column; gap:7px;">`;
        d.videos.forEach((v) => {
          html += `<a class="dlink" href="${esc(v.url)}" target="_blank" rel="noopener" style="display:flex; align-items:center; gap:11px; text-decoration:none; color:var(--text); background:var(--panel2); border-radius:9px; padding:10px 13px; font-size:13px;"><span style="color:var(--accent2);">▶</span><span style="flex:1;">${esc(v.title)}</span><span style="color:var(--dim); font-size:11px;">${esc(v.source || '')}</span></a>`;
        });
        html += `</div></div>`;
      }

      html += `<div style="display:flex; gap:9px; margin-top:24px;">
        ${d.playgroundUrl ? `<a href="${esc(d.playgroundUrl)}" target="_blank" rel="noopener" class="dbtn" style="text-decoration:none; flex:1; text-align:center; font-size:13px; padding:11px; border-radius:9px; border:none; background:linear-gradient(135deg,var(--accent),var(--accent2)); color:#fff; font-weight:600;">Playground ↗</a>` : ''}
        ${d.docsUrl ? `<a href="${esc(d.docsUrl)}" target="_blank" rel="noopener" class="dbtn" style="text-decoration:none; flex:1; text-align:center; font-size:13px; padding:11px; border-radius:9px; border:1px solid var(--border2); background:var(--panel2); color:var(--text);">Docs ↗</a>` : ''}
      </div></div>`;

      detailBody.innerHTML = html;
      detailDrawer.classList.remove('hidden');
      if (window.hljs) detailBody.querySelectorAll('pre code').forEach((b) => window.hljs.highlightElement(b));
      document.getElementById('detail-close').addEventListener('click', closeDetail);
      const copyBtn = document.getElementById('copy-code');
      if (copyBtn) copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(d.code).then(() => { copyBtn.textContent = '✓ Copiado'; setTimeout(() => copyBtn.textContent = 'Copiar', 1600); });
      });
    }
    function closeDetail() { detailDrawer.classList.add('hidden'); }
    detailDrawer.addEventListener('click', (e) => { if (e.target === detailDrawer) closeDetail(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeDetail(); closeCompareOverlay(); } });

    // ── Comparador ─────────────────────────────────────────────────────
    const selected = new Set();
    const tray = document.getElementById('compare-tray');
    const trayCount = document.getElementById('tray-count');
    const trayChips = document.getElementById('tray-chips');

    function renderTray() {
      trayCount.textContent = selected.size;
      trayChips.innerHTML = [...selected].map((id) => {
        const m = decorate(byId[id]);
        return `<span style="display:inline-flex; align-items:center; gap:7px; font-size:12px; color:var(--text); background:var(--panel2); border-radius:8px; padding:4px 7px 4px 11px;"><span style="width:7px;height:7px;border-radius:50%;background:${m.accent};"></span>${esc(m.displayName)}<button data-id="${id}" style="background:none;border:none;color:var(--dim);cursor:pointer;font-family:inherit;font-size:14px;padding:0 2px;">×</button></span>`;
      }).join('');
      tray.classList.toggle('hidden', selected.size === 0);
    }

    function toggleCompare(id) {
      if (selected.has(id)) selected.delete(id);
      else { if (selected.size >= 4) { alert('Máximo 4 modelos para comparar.'); return; } selected.add(id); }
      renderTray();
      document.querySelectorAll(`[data-action="compare"][data-id="${id}"]`).forEach((b) => {
        const on = selected.has(id);
        b.textContent = on ? '✓' : '+';
        b.style.borderColor = on ? 'var(--accent)' : 'var(--border2)';
        b.style.background = on ? 'var(--accent)' : 'transparent';
        b.style.color = on ? '#fff' : 'var(--dim)';
      });
    }

    trayChips.addEventListener('click', (e) => { const b = e.target.closest('button'); if (b) toggleCompare(b.dataset.id); });
    document.getElementById('tray-clear').addEventListener('click', () => { [...selected].forEach((id) => toggleCompare(id)); });

    const compareOverlay = document.getElementById('compare-overlay');
    const compareBody = document.getElementById('compare-body');
    function compareRow(label, value, color) {
      return `<div style="display:flex; justify-content:space-between; padding:6px 0; border-top:1px solid var(--border);"><span style="color:var(--dim);">${label}</span><span style="${color ? `font-family:'IBM Plex Mono',monospace; color:${color};` : 'color:var(--text); text-align:right;'}">${esc(value)}</span></div>`;
    }
    function openCompareOverlay() {
      if (!selected.size) return;
      compareBody.innerHTML = [...selected].map((id) => {
        const c = decorate(byId[id]);
        return `<div style="background:var(--panel2); border:1px solid var(--border); border-radius:12px; padding:16px;">
          <div style="display:flex; align-items:center; gap:8px;"><span style="width:8px;height:8px;border-radius:50%;background:${c.accent};"></span><span style="font-size:10.5px; text-transform:uppercase; letter-spacing:.6px; color:var(--dim);">${esc(c.company)}</span></div>
          <div style="font-size:17px; font-weight:600; color:var(--head); margin-top:6px;">${esc(c.displayName)}</div>
          <div style="display:flex; flex-direction:column; gap:0; margin-top:13px; font-size:12.5px;">
            ${compareRow('Origen', c.originLabel)}
            ${compareRow('In /1M', c.priceInText, 'var(--accent2)')}
            ${compareRow('Out /1M', c.priceOutText, 'var(--accent)')}
            ${compareRow('Contexto', c.contextText, 'var(--warn)')}
            ${compareRow('SWE-bench', c.sweCell, 'var(--pos)')}
            ${compareRow('Licencia', c.licenseText)}
            ${compareRow('Modalidades', c.modalText)}
          </div>
          <button class="dbtn" data-remove="${c.id}" style="width:100%; margin-top:12px; font-family:inherit; font-size:12px; padding:7px; border-radius:8px; border:1px solid var(--border2); background:transparent; color:var(--dim);">quitar</button>
        </div>`;
      }).join('');
      compareOverlay.classList.remove('hidden');
    }
    function closeCompareOverlay() { compareOverlay.classList.add('hidden'); }
    document.getElementById('tray-open').addEventListener('click', openCompareOverlay);
    document.getElementById('compare-close').addEventListener('click', closeCompareOverlay);
    compareOverlay.addEventListener('click', (e) => { if (e.target === compareOverlay) closeCompareOverlay(); });
    compareBody.addEventListener('click', (e) => {
      const b = e.target.closest('[data-remove]');
      if (b) { toggleCompare(b.dataset.remove); if (!selected.size) closeCompareOverlay(); else openCompareOverlay(); }
    });

    // ── Delegación global de clics ─────────────────────────────────────
    document.addEventListener('click', (e) => {
      const cp = e.target.closest('[data-company-pick]');
      if (cp) { enterCompany(cp.dataset.companyPick); return; }
      const cb = e.target.closest('#company-back');
      if (cb) { exitCompany(); return; }
      const cf = e.target.closest('[data-company-filter]');
      if (cf) { filterByCompany(cf.dataset.companyFilter); return; }
      const cmp = e.target.closest('[data-action="compare"]');
      if (cmp) { e.stopPropagation(); toggleCompare(cmp.dataset.id); return; }
      const det = e.target.closest('[data-action="detail"]');
      if (det) { openDetail(det.dataset.id); return; }
      const row = e.target.closest('.drow');
      if (row) { openDetail(row.dataset.id); return; }
    });

    applyFilters();
  </script>
</Layout>
