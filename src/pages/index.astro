---
import { models, companies } from '../data/models';
import type { Model } from '../data/types';

const catLabels: Record<string, string> = {
  coding: 'Código', reasoning: 'Razonamiento', agentic: 'Agéntico', general: 'General',
  multimodal: 'Multimodal', fast: 'Rápido', budget: 'Económico', tool: 'Herramienta',
};
const originLabels: Record<string, string> = { US: 'EE. UU.', EU: 'Europa', China: 'China', Open: 'Open' };

const stats = {
  models: models.filter((m) => m.kind === 'model').length,
  tools: models.filter((m) => m.kind === 'tool').length,
  companies: Object.keys(companies).length,
  open: models.filter((m) => m.openWeight).length,
};

const originChips = ['all', 'US', 'China', 'EU', 'Open'];
const catChips = ['all', 'coding', 'reasoning', 'agentic', 'multimodal', 'fast', 'budget', 'general', 'tool'];

const fmtCtx = (n: number | null) => (n == null ? '—' : n >= 1_000_000 ? `${n / 1_000_000}M` : `${Math.round(n / 1000)}K`);
const fmtPrice = (p: number | null) => (p == null ? '—' : `$${p}`);
const fmtDate = (s?: string) => {
  if (!s) return '—';
  const [y, m] = s.split('-');
  const mes = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][parseInt(m, 10) - 1] || '';
  return mes ? `${mes} ${y}` : y;
};

function decorate(m: Model) {
  const c = companies[m.company] || { name: m.company, accent: '#888888' };
  const pIn = m.pricing.inputPer1M, pOut = m.pricing.outputPer1M;
  const priceText = (pIn == null && pOut == null) ? 'suscripción' : (`$${pIn}/$${pOut}${m.pricing.approx ? '~' : ''}`);
  const notes = m.notes || '';
  const notesShort = notes.length > 130 ? notes.slice(0, 128) + '…' : notes;
  return {
    ...m,
    accent: c.accent,
    companyName: c.name,
    kindLabel: m.kind === 'tool' ? 'agente' : 'modelo',
    originLabel: originLabels[m.origin] || m.origin,
    cats: m.category.slice(0, 3).map((k) => catLabels[k] || k),
    contextText: fmtCtx(m.context),
    priceText,
    priceInText: fmtPrice(pIn) + (m.pricing.approx && pIn != null ? '~' : ''),
    priceOutText: fmtPrice(pOut) + (m.pricing.approx && pOut != null ? '~' : ''),
    priceNote: m.pricing.note || null,
    openWeight: !!m.openWeight,
    swe: m.benchmarks?.sweBenchPro || null,
    sweText: m.benchmarks?.sweBenchPro ? `${m.benchmarks.sweBenchPro}%` : '',
    sweCell: m.benchmarks?.sweBenchPro ? `${m.benchmarks.sweBenchPro}%` : '—',
    notesShort,
    modalText: m.modalities.join(' · '),
    licenseText: m.license || (m.openWeight ? 'open-weight' : 'propietario'),
    releaseText: fmtDate(m.releaseDate),
    hasVideos: !!(m.videos && m.videos.length),
    hasCode: !!(m.examples && m.examples.length),
    code: m.examples?.[0]?.code || '',
    codeLang: m.examples?.[0]?.lang || '',
    codeTitle: m.examples?.[0]?.title || '',
    api: m.apiModelString || '—',
  };
}

const decorated = models.map(decorate);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Catálogo de modelos de IA para programación agrupados por empresa: precios, contexto, ejemplos de uso, playgrounds y vídeos." />
  <title>Catálogo de Modelos de IA para Programación</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧩</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,300;6..72,400;6..72,500;6..72,600;6..72,700&family=Archivo:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
</head>
<body>
  <div class="edl escroll" id="edl-root" data-theme="light" style="min-height:100vh; background:var(--bg); color:var(--ink); font-family:'Archivo',-apple-system,sans-serif; font-size:15px; line-height:1.55;">

    <!-- masthead -->
    <div style="border-bottom:2px solid var(--ink); background:var(--bg); position:sticky; top:0; z-index:40;">
      <div style="max-width:1140px; margin:0 auto; padding:14px 28px; display:flex; align-items:center; gap:18px;">
        <span style="font-family:'Newsreader',serif; font-size:23px; font-weight:600; letter-spacing:-.3px; color:var(--ink);">Modelos de IA</span>
        <span style="font-size:11px; letter-spacing:2.5px; text-transform:uppercase; color:var(--dim); border-left:1px solid var(--rule); padding-left:18px;">Catálogo para programar</span>
        <nav style="margin-left:auto; display:flex; gap:14px; align-items:center;">
          <a href="./local.html" class="elink" style="font-size:11.5px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Locales</a>
          <a href="./tools.html" class="elink" style="font-size:11.5px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Herramientas</a>
          <a href="./benchmarks.html" class="elink" style="font-size:11.5px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Benchmarks</a>
        </nav>
        <span style="font-size:11.5px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Edición · junio 2026</span>
        <button class="ebtn" id="theme-toggle" style="background:transparent; color:var(--ink); border:1px solid var(--rule); padding:5px 13px; font-family:inherit; font-size:12px; border-radius:20px;">☾ Modo oscuro</button>
      </div>
    </div>

    <!-- hero -->
    <div style="max-width:1140px; margin:0 auto; padding:54px 28px 0;">
      <div style="font-size:11.5px; letter-spacing:3px; text-transform:uppercase; color:var(--accent); font-weight:600;">Panorama 2026 · Coding & Agentes</div>
      <h1 style="font-family:'Newsreader',serif; font-weight:500; font-size:clamp(40px,7vw,78px); line-height:1.02; letter-spacing:-1.5px; margin:18px 0 0; max-width:11ch; color:var(--ink);">El catálogo de modelos para <em style="font-style:italic; color:var(--accent);">programar</em></h1>
      <div style="display:grid; grid-template-columns:1.6fr 1fr; gap:40px; margin-top:30px; align-items:end;">
        <p class="edl-lede" style="font-family:'Newsreader',serif; font-size:19px; line-height:1.5; color:var(--ink); margin:0; max-width:54ch;">Una guía viva de los modelos y agentes de IA disponibles hoy para escribir código. Precios por millón de tokens, ventana de contexto, benchmarks, ejemplos listos para pegar y enlaces a cada playground. Las cifras corresponden a junio de 2026; conviene confirmar siempre el precio oficial antes de presupuestar.</p>
        <div style="display:flex; flex-direction:column; gap:0; border-top:1px solid var(--ink);">
          <div style="display:flex; justify-content:space-between; align-items:baseline; padding:9px 0; border-bottom:1px solid var(--rule);"><span style="font-family:'Newsreader',serif; font-size:30px; color:var(--ink);">{stats.models}</span><span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">Modelos</span></div>
          <div style="display:flex; justify-content:space-between; align-items:baseline; padding:9px 0; border-bottom:1px solid var(--rule);"><span style="font-family:'Newsreader',serif; font-size:30px; color:var(--ink);">{stats.tools}</span><span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">Agentes</span></div>
          <div style="display:flex; justify-content:space-between; align-items:baseline; padding:9px 0; border-bottom:1px solid var(--rule);"><span style="font-family:'Newsreader',serif; font-size:30px; color:var(--ink);">{stats.companies}</span><span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">Empresas</span></div>
          <div style="display:flex; justify-content:space-between; align-items:baseline; padding:9px 0;"><span style="font-family:'Newsreader',serif; font-size:30px; color:var(--ink);">{stats.open}</span><span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">Open-weight</span></div>
        </div>
      </div>
    </div>

    <!-- filters -->
    <div style="max-width:1140px; margin:42px auto 0; padding:0 28px;">
      <div style="border-top:1px solid var(--ink); border-bottom:1px solid var(--rule); padding:14px 0; display:flex; align-items:center; gap:12px;">
        <span style="color:var(--faint); font-size:18px;">⌕</span>
        <input id="search" placeholder="Buscar un modelo, empresa o tecnología…" spellcheck="false" style="flex:1; background:transparent; border:none; outline:none; color:var(--ink); font-family:'Newsreader',serif; font-size:20px;" autocomplete="off" />
        <span id="result-label" style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">{models.length} resultados</span>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:24px 36px; padding:16px 0 2px; align-items:center;">
        <div style="display:flex; align-items:baseline; gap:14px;">
          <span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--faint);">Origen</span>
          <div style="display:flex; gap:14px;" id="origin-chips">
            {originChips.map((o) => (
              <button class="efilter" data-origin={o} data-active={o==='all'?'true':'false'} style={`font-size:14px; padding:0 0 2px; color:${o==='all'?'var(--accent)':'var(--ink)'}; font-weight:${o==='all'?700:400}; border-bottom:2px solid ${o==='all'?'var(--accent)':'transparent'};`}>
                {o==='all'?'Todos':(originLabels[o]||o)}
              </button>
            ))}
          </div>
        </div>
        <div style="display:flex; align-items:baseline; gap:14px; flex-wrap:wrap;">
          <span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--faint);">Categoría</span>
          <div style="display:flex; gap:14px; flex-wrap:wrap;" id="cat-chips">
            {catChips.map((c) => (
              <button class="efilter" data-cat={c} data-active={c==='all'?'true':'false'} style={`font-size:14px; padding:0 0 2px; color:${c==='all'?'var(--accent)':'var(--ink)'}; font-weight:${c==='all'?700:400}; border-bottom:2px solid ${c==='all'?'var(--accent)':'transparent'};`}>
                {c==='all'?'Todas':(catLabels[c]||c)}
              </button>
            ))}
          </div>
        </div>
        <div style="margin-left:auto; display:flex; align-items:center; gap:14px;">
          <button class="efilter" id="btn-grid" data-active="true" style="font-size:13px; letter-spacing:.5px; text-transform:uppercase; color:var(--accent); font-weight:700;">Retícula</button>
          <span style="color:var(--rule);">/</span>
          <button class="efilter" id="btn-table" data-active="false" style="font-size:13px; letter-spacing:.5px; text-transform:uppercase; color:var(--dim); font-weight:400;">Tabla</button>
        </div>
      </div>
    </div>

    <!-- content -->
    <div style="max-width:1140px; margin:0 auto; padding:30px 28px 150px;">

      <div id="empty" class="hidden" style="padding:70px 0; text-align:center; color:var(--dim); font-family:'Newsreader',serif; font-size:21px; font-style:italic;">No se ha encontrado ningún modelo con ese criterio.</div>

      <!-- GRID -->
      <div id="grid-view">
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(330px,1fr)); gap:26px;">
          {decorated.map((m) => (
            <div class="ecard" data-id={m.id} data-name={m.displayName.toLowerCase()} data-company={m.company.toLowerCase()} data-api={(m.apiModelString??'').toLowerCase()} data-notes={(m.notes??'').toLowerCase()} data-origin={m.origin} data-cats={m.category.join(' ')} data-kind={m.kind} style="background:var(--panel); border:1px solid var(--border); border-radius:3px; padding:24px; display:flex; flex-direction:column;">
              <div style="display:flex; align-items:center; gap:8px;">
                <span style={`width:9px; height:9px; border-radius:50%; background:${m.accent};`}></span>
                <span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">{m.companyName}</span>
                <span style="margin-left:auto; font-size:10.5px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">{m.kindLabel}</span>
              </div>
              <h3 style="font-family:'Newsreader',serif; font-weight:500; font-size:25px; line-height:1.1; letter-spacing:-.4px; margin:12px 0 3px; color:var(--ink);">{m.displayName}</h3>
              <div style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--accenttext); min-height:15px;">{m.api}</div>
              <div style="height:1px; background:var(--rule); margin:14px 0;"></div>
              <p style="font-family:'Newsreader',serif; font-size:15.5px; line-height:1.5; color:var(--dim); margin:0; flex:1;">{m.notesShort}</p>
              <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:14px;">
                <span style="font-size:11px; color:var(--ink); border:1px solid var(--rule); border-radius:20px; padding:3px 10px;">{m.originLabel}</span>
                {m.cats.map((cat) => <span style="font-size:11px; color:var(--dim); border:1px solid var(--rule); border-radius:20px; padding:3px 10px;">{cat}</span>)}
                {m.openWeight && <span style="font-size:11px; color:var(--accent); border:1px solid var(--accent); border-radius:20px; padding:3px 10px;">open-weight</span>}
              </div>
              <div style="display:flex; gap:20px; margin-top:16px; padding-top:15px; border-top:1px solid var(--rule);">
                <div><div style="font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Precio /1M</div><div style="font-family:'Newsreader',serif; font-size:17px; color:var(--ink); margin-top:1px;">{m.priceText}</div></div>
                <div><div style="font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">Contexto</div><div style="font-family:'Newsreader',serif; font-size:17px; color:var(--ink); margin-top:1px;">{m.contextText}</div></div>
                {m.swe != null && <div><div style="font-size:10px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">SWE-bench</div><div style="font-family:'Newsreader',serif; font-size:17px; color:var(--accent); margin-top:1px;">{m.sweText}</div></div>}
              </div>
              <div style="display:flex; gap:9px; margin-top:18px;">
                <button class="ebtn" data-action="detail" data-id={m.id} style="flex:1; font-family:inherit; font-size:13px; padding:9px; border-radius:2px; border:1px solid var(--ink); background:var(--ink); color:var(--panel);">Leer ficha</button>
                <button class="ebtn" data-action="compare" data-id={m.id} style="font-family:inherit; font-size:13px; padding:9px 14px; border-radius:2px; border:1px solid var(--rule); background:transparent; color:var(--dim);">+ comparar</button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- TABLE -->
      <div id="table-view" class="hidden">
        <div style="overflow-x:auto;" class="escroll">
          <table style="width:100%; border-collapse:collapse; min-width:820px;">
            <thead>
              <tr style="border-bottom:2px solid var(--ink); text-align:left;">
                <th style="padding:12px 14px 12px 0; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600;">Modelo</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600;">Empresa</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600;">Origen</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600; text-align:right;">In /1M</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600; text-align:right;">Out /1M</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600; text-align:right;">Contexto</th>
                <th style="padding:12px 14px; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim); font-weight:600; text-align:right;">SWE</th>
              </tr>
            </thead>
            <tbody id="table-body">
              {decorated.map((m) => (
                <tr class="erow" data-id={m.id} data-name={m.displayName.toLowerCase()} data-company={m.company.toLowerCase()} data-api={(m.apiModelString??'').toLowerCase()} data-notes={(m.notes??'').toLowerCase()} data-origin={m.origin} data-cats={m.category.join(' ')} data-kind={m.kind} style="border-bottom:1px solid var(--rule); cursor:pointer;">
                  <td style="padding:13px 14px 13px 0;"><span style={`display:inline-block; width:8px; height:8px; border-radius:50%; background:${m.accent}; margin-right:9px;`}></span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">{m.displayName}</span></td>
                  <td style="padding:13px 14px; color:var(--dim); font-size:14px;">{m.companyName}</td>
                  <td style="padding:13px 14px; color:var(--ink); font-size:14px;">{m.originLabel}</td>
                  <td style="padding:13px 14px; text-align:right; font-family:'Newsreader',serif; font-size:16px; color:var(--ink);">{m.priceInText}</td>
                  <td style="padding:13px 14px; text-align:right; font-family:'Newsreader',serif; font-size:16px; color:var(--ink);">{m.priceOutText}</td>
                  <td style="padding:13px 14px; text-align:right; font-family:'Newsreader',serif; font-size:16px; color:var(--ink);">{m.contextText}</td>
                  <td style="padding:13px 14px; text-align:right; font-family:'Newsreader',serif; font-size:16px; color:var(--accent);">{m.sweCell}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- compare tray -->
    <div id="compare-tray" class="hidden" style="position:fixed; left:0; right:0; bottom:0; z-index:45; background:var(--panel); border-top:2px solid var(--ink); padding:13px 28px; box-shadow:0 -10px 40px -20px rgba(0,0,0,.3);">
      <div style="max-width:1140px; margin:0 auto; display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
        <span style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--dim);">Comparar · <span id="tray-count">0</span>/4</span>
        <div id="tray-chips" style="display:flex; gap:8px; flex-wrap:wrap; flex:1;"></div>
        <button class="elink" id="tray-clear" style="background:none; border:none; font-family:inherit; font-size:13px; color:var(--dim); cursor:pointer;">vaciar</button>
        <button class="ebtn" id="tray-open" style="font-family:inherit; font-size:13px; padding:9px 20px; border-radius:2px; border:1px solid var(--accent); background:var(--accent); color:#fff; font-weight:600;">Ver comparativa →</button>
      </div>
    </div>

    <!-- detail -->
    <div id="detail-drawer" class="hidden" style="position:fixed; inset:0; z-index:60;">
      <div id="detail-backdrop" style="position:absolute; inset:0; background:rgba(20,15,8,.4);"></div>
      <div id="detail-panel" class="escroll" style="width:min(600px,100%); height:100%; overflow-y:auto; background:var(--panel); animation:edlslide .25s ease both; margin-left:auto;">
        <div style="padding:30px 38px 60px;" id="detail-body"></div>
      </div>
    </div>

    <!-- compare overlay -->
    <div id="compare-overlay" class="hidden" style="position:fixed; inset:0; z-index:65; background:rgba(20,15,8,.45); display:flex; align-items:center; justify-content:center; padding:28px;">
      <div id="compare-panel" class="escroll" style="width:min(1080px,100%); max-height:88vh; overflow:auto; background:var(--panel); border-radius:5px;">
        <div style="position:sticky; top:0; background:var(--panel); border-bottom:2px solid var(--ink); padding:18px 24px; display:flex; align-items:center; gap:12px;">
          <span style="font-family:'Newsreader',serif; font-size:24px; color:var(--ink);">Comparativa</span>
          <button class="ebtn" id="compare-close" style="margin-left:auto; background:transparent; color:var(--ink); border:1px solid var(--rule); padding:5px 14px; font-family:inherit; font-size:12px; border-radius:20px;">Cerrar ✕</button>
        </div>
        <div id="compare-body" style="padding:24px; display:grid; gap:20px; grid-template-columns:repeat(auto-fit,minmax(230px,1fr));"></div>
      </div>
    </div>

  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

  <script type="application/json" id="model-data" is:inline set:html={JSON.stringify({ models, companies, catLabels, originLabels })}></script>

  <script>
    const DATA = JSON.parse(document.getElementById('model-data').textContent);
    const byId = Object.fromEntries(DATA.models.map((m) => [m.id, m]));
    const C = DATA.companies, CAT = DATA.catLabels, ORI = DATA.originLabels;

    const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const fmtCtx = (n) => n == null ? '—' : n >= 1e6 ? `${n / 1e6}M` : `${Math.round(n / 1000)}K`;
    const fmtPrice = (p) => p == null ? '—' : `$${p}`;
    const fmtDate = (s) => {
      if (!s) return '—';
      const [y, m] = s.split('-');
      const mes = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][parseInt(m,10)-1] || '';
      return mes ? `${mes} ${y}` : y;
    };

    function decorate(m) {
      const c = C[m.company] || { name: m.company, accent: '#888888' };
      const pIn = m.pricing.inputPer1M, pOut = m.pricing.outputPer1M;
      const priceText = (pIn == null && pOut == null) ? 'suscripción' : (`$${pIn}/$${pOut}${m.pricing.approx ? '~' : ''}`);
      const notes = m.notes || '';
      const notesShort = notes.length > 130 ? notes.slice(0, 128) + '…' : notes;
      return {
        raw: m, id: m.id, displayName: m.displayName, company: c.name, accent: c.accent,
        api: m.apiModelString || '—', kindLabel: m.kind === 'tool' ? 'agente' : 'modelo',
        originLabel: ORI[m.origin] || m.origin,
        cats: m.category.slice(0, 3).map((k) => CAT[k] || k),
        contextText: fmtCtx(m.context),
        priceText,
        priceInText: fmtPrice(pIn) + (m.pricing.approx && pIn != null ? '~' : ''),
        priceOutText: fmtPrice(pOut) + (m.pricing.approx && pOut != null ? '~' : ''),
        priceNote: m.pricing.note || null,
        openWeight: !!m.openWeight,
        swe: (m.benchmarks && m.benchmarks.sweBenchPro) || null,
        sweText: (m.benchmarks && m.benchmarks.sweBenchPro) ? (m.benchmarks.sweBenchPro + '%') : '',
        sweCell: (m.benchmarks && m.benchmarks.sweBenchPro) ? (m.benchmarks.sweBenchPro + '%') : '—',
        notes,
        notesShort,
        modalText: m.modalities.join(' · '),
        licenseText: m.license || (m.openWeight ? 'open-weight' : 'propietario'),
        releaseText: fmtDate(m.releaseDate),
        playgroundUrl: m.playgroundUrl || null, docsUrl: m.docsUrl || null,
        videos: m.videos || [], hasVideos: !!(m.videos && m.videos.length),
        hasCode: !!(m.examples && m.examples.length),
        code: (m.examples && m.examples[0]) ? m.examples[0].code : '',
        codeLang: (m.examples && m.examples[0]) ? m.examples[0].lang : '',
        codeTitle: (m.examples && m.examples[0]) ? m.examples[0].title : '',
      };
    }

    // ── Tema ──────────────────────────────────────────────
    const root = document.getElementById('edl-root');
    const themeBtn = document.getElementById('theme-toggle');
    const savedTheme = localStorage.getItem('edl-theme');
    if (savedTheme) root.setAttribute('data-theme', savedTheme);
    const isDark = root.getAttribute('data-theme') === 'dark';
    themeBtn.textContent = isDark ? '☀ Modo claro' : '☾ Modo oscuro';
    themeBtn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      localStorage.setItem('edl-theme', next);
      themeBtn.textContent = next === 'dark' ? '☀ Modo claro' : '☾ Modo oscuro';
    });

    // ── Filtros ───────────────────────────────────────────
    let q = '', origin = 'all', cat = 'all';
    const resultLabel = document.getElementById('result-label');

    function matches(el) {
      const name = el.dataset.name || '';
      const company = el.dataset.company || '';
      const api = el.dataset.api || '';
      const notes = el.dataset.notes || '';
      if (q && !(name + ' ' + company + ' ' + api + ' ' + notes).includes(q)) return false;
      if (origin !== 'all' && el.dataset.origin !== origin) return false;
      if (cat !== 'all') {
        const cats = (el.dataset.cats || '').split(' ');
        if (!cats.includes(cat)) return false;
      }
      return true;
    }

    function applyFilters() {
      let shown = 0;
      document.querySelectorAll('.ecard').forEach((el) => {
        const ok = matches(el); el.classList.toggle('hidden', !ok); if (ok) shown++;
      });
      document.querySelectorAll('.erow').forEach((el) => {
        const ok = matches(el); el.classList.toggle('hidden', !ok); if (ok) shown++;
      });
      const empty = document.getElementById('empty');
      const grid = document.getElementById('grid-view');
      const table = document.getElementById('table-view');
      const isGrid = !grid.classList.contains('hidden');
      resultLabel.textContent = shown + ' resultados';
      if (shown === 0) {
        grid.classList.add('hidden');
        table.classList.add('hidden');
        empty.classList.remove('hidden');
      } else {
        empty.classList.add('hidden');
        if (isGrid) { grid.classList.remove('hidden'); table.classList.add('hidden'); }
        else { grid.classList.add('hidden'); table.classList.remove('hidden'); }
      }
    }

    document.getElementById('search').addEventListener('input', (e) => {
      q = e.target.value.toLowerCase().trim();
      applyFilters();
    });

    function setFilterActive(group, value, attr) {
      group.querySelectorAll('.efilter').forEach((btn) => {
        const active = btn.dataset[attr] === value;
        btn.style.color = active ? 'var(--accent)' : 'var(--ink)';
        btn.style.fontWeight = active ? '700' : '400';
        btn.style.borderBottomColor = active ? 'var(--accent)' : 'transparent';
        btn.dataset.active = active ? 'true' : 'false';
      });
    }

    document.getElementById('origin-chips').addEventListener('click', (e) => {
      const btn = e.target.closest('.efilter'); if (!btn) return;
      origin = btn.dataset.origin;
      setFilterActive(document.getElementById('origin-chips'), origin, 'origin');
      applyFilters();
    });

    document.getElementById('cat-chips').addEventListener('click', (e) => {
      const btn = e.target.closest('.efilter'); if (!btn) return;
      cat = btn.dataset.cat;
      setFilterActive(document.getElementById('cat-chips'), cat, 'cat');
      applyFilters();
    });

    // Vista
    const btnGrid = document.getElementById('btn-grid');
    const btnTable = document.getElementById('btn-table');
    function setView(v) {
      const grid = document.getElementById('grid-view');
      const table = document.getElementById('table-view');
      if (v === 'grid') {
        grid.classList.remove('hidden'); table.classList.add('hidden');
        btnGrid.style.color = 'var(--accent)'; btnGrid.style.fontWeight = '700';
        btnTable.style.color = 'var(--dim)'; btnTable.style.fontWeight = '400';
      } else {
        grid.classList.add('hidden'); table.classList.remove('hidden');
        btnGrid.style.color = 'var(--dim)'; btnGrid.style.fontWeight = '400';
        btnTable.style.color = 'var(--accent)'; btnTable.style.fontWeight = '700';
      }
      applyFilters();
    }
    btnGrid.addEventListener('click', () => setView('grid'));
    btnTable.addEventListener('click', () => setView('table'));

    // ── Detalle lateral ───────────────────────────────────
    const detailDrawer = document.getElementById('detail-drawer');
    const detailBody = document.getElementById('detail-body');

    function openDetail(id) {
      const d = decorate(byId[id]); if (!d) return;
      let html = `
        <div style="display:flex; align-items:center; gap:10px;">
          <span style="width:9px; height:9px; border-radius:50%; background:${d.accent};"></span>
          <span style="font-size:11px; letter-spacing:1.8px; text-transform:uppercase; color:var(--dim);">${esc(d.company)}</span>
          <button class="ebtn" id="detail-close" style="margin-left:auto; background:transparent; color:var(--ink); border:1px solid var(--rule); padding:5px 14px; font-family:inherit; font-size:12px; border-radius:20px;">Cerrar ✕</button>
        </div>
        <h2 style="font-family:'Newsreader',serif; font-weight:500; font-size:40px; line-height:1.05; letter-spacing:-1px; margin:14px 0 4px; color:var(--ink);">${esc(d.displayName)}</h2>
        <div style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--accenttext); min-height:17px;">${esc(d.api)}</div>
        <p style="font-family:'Newsreader',serif; font-size:19px; line-height:1.5; color:var(--ink); margin:18px 0 0;">${esc(d.notes)}</p>
        <div style="display:flex; flex-wrap:wrap; gap:7px; margin-top:18px;">
          <span style="font-size:11.5px; color:var(--ink); border:1px solid var(--rule); border-radius:20px; padding:4px 12px;">${esc(d.originLabel)}</span>
          ${d.cats.map((c) => `<span style="font-size:11.5px; color:var(--dim); border:1px solid var(--rule); border-radius:20px; padding:4px 12px;">${esc(c)}</span>`).join('')}
          ${d.openWeight ? `<span style="font-size:11.5px; color:var(--accent); border:1px solid var(--accent); border-radius:20px; padding:4px 12px;">open-weight</span>` : ''}
        </div>
        <div style="margin-top:24px; border-top:1px solid var(--ink);">
          <div style="display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--rule);"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Entrada /1M</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.priceInText)}</span></div>
          <div style="display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--rule);"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Salida /1M</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.priceOutText)}</span></div>
          <div style="display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--rule);"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Contexto</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.contextText)}</span></div>
          <div style="display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--rule);"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Modalidades</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.modalText)}</span></div>
          <div style="display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--rule);"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Licencia</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.licenseText)}</span></div>
          <div style="display:flex; justify-content:space-between; padding:11px 0;"><span style="font-size:12px; letter-spacing:1px; text-transform:uppercase; color:var(--dim);">Lanzamiento</span><span style="font-family:'Newsreader',serif; font-size:18px; color:var(--ink);">${esc(d.releaseText)}</span></div>
        </div>`;

      if (d.priceNote) {
        html += `<div style="margin-top:14px; font-family:'Newsreader',serif; font-style:italic; font-size:15px; color:var(--dim); border-left:2px solid var(--accent); padding-left:14px;">${esc(d.priceNote)}</div>`;
      }

      if (d.hasCode) {
        html += `<div style="margin-top:28px;">
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:9px;">
            <span style="font-family:'Newsreader',serif; font-size:21px; color:var(--ink);">Cómo empezar</span>
            <span style="font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--faint);">${esc(d.codeLang)}</span>
            <button class="ebtn" id="copy-code" style="margin-left:auto; font-family:inherit; font-size:12px; padding:5px 13px; border-radius:20px; border:1px solid var(--rule); background:transparent; color:var(--ink);">Copiar</button>
          </div>
          <pre class="escroll" style="margin:0; background:var(--ink); color:#ece4d6; border-radius:4px; padding:16px 18px; overflow-x:auto; font-family:'JetBrains Mono',monospace; font-size:12.5px; line-height:1.6;"><code>${esc(d.code)}</code></pre>
        </div>`;
      }

      if (d.hasVideos) {
        html += `<div style="margin-top:28px;">
          <div style="font-family:'Newsreader',serif; font-size:21px; color:var(--ink); margin-bottom:11px;">Vídeos de referencia</div>
          <div style="display:flex; flex-direction:column;">`;
        d.videos.forEach((v) => {
          html += `<a class="elink" href="${esc(v.url)}" target="_blank" rel="noopener" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:var(--ink); border-top:1px solid var(--rule); padding:12px 0; font-size:15px;"><span style="color:var(--accent);">▶</span><span style="flex:1; font-family:'Newsreader',serif; font-size:16px;">${esc(v.title)}</span><span style="color:var(--faint); font-size:11px;">${esc(v.source||'')}</span></a>`;
        });
        html += `</div></div>`;
      }

      html += `<div style="display:flex; gap:10px; margin-top:28px;">
        ${d.playgroundUrl ? `<a href="${esc(d.playgroundUrl)}" target="_blank" rel="noopener" class="ebtn" style="text-decoration:none; flex:1; text-align:center; font-size:14px; padding:11px; border-radius:2px; border:1px solid var(--accent); background:var(--accent); color:#fff; font-weight:600;">Abrir playground ↗</a>` : ''}
        ${d.docsUrl ? `<a href="${esc(d.docsUrl)}" target="_blank" rel="noopener" class="ebtn" style="text-decoration:none; flex:1; text-align:center; font-size:14px; padding:11px; border-radius:2px; border:1px solid var(--ink); background:transparent; color:var(--ink);">Documentación ↗</a>` : ''}
      </div>`;

      detailBody.innerHTML = html;
      detailDrawer.classList.remove('hidden');
      if (window.hljs) detailBody.querySelectorAll('pre code').forEach((b) => window.hljs.highlightElement(b));

      // Close button inside drawer
      document.getElementById('detail-close').addEventListener('click', closeDetail);
      // Copy button
      const copyBtn = document.getElementById('copy-code');
      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(d.code).then(() => {
            copyBtn.textContent = '✓ Copiado';
            setTimeout(() => copyBtn.textContent = 'Copiar', 1600);
          });
        });
      }
    }

    function closeDetail() { detailDrawer.classList.add('hidden'); }
    document.getElementById('detail-backdrop').addEventListener('click', closeDetail);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeDetail(); closeCompareOverlay(); } });

    // Delegación grid
    document.getElementById('grid-view').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action="detail"]');
      if (btn) { e.stopPropagation(); openDetail(btn.dataset.id); }
    });
    // Delegación tabla
    document.getElementById('table-body').addEventListener('click', (e) => {
      const row = e.target.closest('.erow');
      if (row && !e.target.closest('[data-action]')) openDetail(row.dataset.id);
    });

    // ── Comparador ────────────────────────────────────────
    const selected = new Set();
    const tray = document.getElementById('compare-tray');
    const trayCount = document.getElementById('tray-count');
    const trayChips = document.getElementById('tray-chips');

    function renderTray() {
      trayCount.textContent = selected.size;
      trayChips.innerHTML = [...selected].map((id) => {
        const m = decorate(byId[id]);
        return `<span style="display:inline-flex; align-items:center; gap:8px; font-family:'Newsreader',serif; font-size:15px; color:var(--ink); border:1px solid var(--rule); border-radius:20px; padding:3px 8px 3px 12px;"><span style="width:7px;height:7px;border-radius:50%;background:${m.accent};"></span>${esc(m.displayName)}<button data-id="${id}" style="background:none;border:none;color:var(--faint);cursor:pointer;font-family:inherit;font-size:15px;padding:0 2px;">×</button></span>`;
      }).join('');
      tray.classList.toggle('hidden', selected.size === 0);
    }

    function toggleCompare(id) {
      if (selected.has(id)) { selected.delete(id); }
      else {
        if (selected.size >= 4) { alert('Máximo 4 modelos para comparar.'); return false; }
        selected.add(id);
      }
      renderTray();
      document.querySelectorAll(`[data-action="compare"][data-id="${id}"]`).forEach((b) => {
        const inCmp = selected.has(id);
        b.textContent = inCmp ? '✓' : '+ comparar';
        b.style.borderColor = inCmp ? 'var(--accent)' : 'var(--rule)';
        b.style.background = inCmp ? 'var(--accent)' : 'transparent';
        b.style.color = inCmp ? '#fff' : 'var(--dim)';
      });
      return true;
    }

    document.getElementById('grid-view').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action="compare"]');
      if (btn) { e.stopPropagation(); toggleCompare(btn.dataset.id); }
    });

    trayChips.addEventListener('click', (e) => {
      const b = e.target.closest('button'); if (!b) return;
      toggleCompare(b.dataset.id);
    });

    document.getElementById('tray-clear').addEventListener('click', () => {
      [...selected].forEach((id) => toggleCompare(id));
    });

    // Overlay comparación
    const compareOverlay = document.getElementById('compare-overlay');
    const compareBody = document.getElementById('compare-body');

    function openCompareOverlay() {
      if (!selected.size) return;
      const list = [...selected].map((id) => decorate(byId[id]));
      let html = '';
      list.forEach((c) => {
        html += `<div style="border:1px solid var(--border); border-radius:3px; padding:18px;">
          <div style="display:flex; align-items:center; gap:8px;"><span style="width:8px;height:8px;border-radius:50%;background:${c.accent};"></span><span style="font-size:10.5px; letter-spacing:1.2px; text-transform:uppercase; color:var(--dim);">${esc(c.company)}</span></div>
          <div style="font-family:'Newsreader',serif; font-size:23px; line-height:1.1; color:var(--ink); margin-top:6px;">${esc(c.displayName)}</div>
          <div style="margin-top:14px;">
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">Origen</span><span style="color:var(--ink);">${esc(c.originLabel)}</span></div>
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">In /1M</span><span style="font-family:'Newsreader',serif; font-size:15px; color:var(--ink);">${esc(c.priceInText)}</span></div>
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">Out /1M</span><span style="font-family:'Newsreader',serif; font-size:15px; color:var(--ink);">${esc(c.priceOutText)}</span></div>
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">Contexto</span><span style="font-family:'Newsreader',serif; font-size:15px; color:var(--ink);">${esc(c.contextText)}</span></div>
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">SWE-bench</span><span style="font-family:'Newsreader',serif; font-size:15px; color:var(--accent);">${esc(c.sweCell)}</span></div>
            <div style="display:flex; justify-content:space-between; padding:7px 0; border-top:1px solid var(--rule); font-size:13px;"><span style="color:var(--dim);">Licencia</span><span style="color:var(--ink); text-align:right;">${esc(c.licenseText)}</span></div>
          </div>
          <button class="elink" data-remove="${c.id}" style="width:100%; margin-top:12px; background:none; border:1px solid var(--rule); border-radius:2px; padding:6px; font-family:inherit; font-size:12px; color:var(--dim); cursor:pointer;">quitar</button>
        </div>`;
      });
      compareBody.innerHTML = html;
      compareOverlay.classList.remove('hidden');
    }

    function closeCompareOverlay() { compareOverlay.classList.add('hidden'); }
    document.getElementById('tray-open').addEventListener('click', openCompareOverlay);
    document.getElementById('compare-close').addEventListener('click', closeCompareOverlay);
    compareOverlay.addEventListener('click', (e) => { if (e.target === compareOverlay) closeCompareOverlay(); });
    compareBody.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-remove]');
      if (btn) { toggleCompare(btn.dataset.remove); if (!selected.size) closeCompareOverlay(); else openCompareOverlay(); }
    });
  </script>

  <style is:global>
    * { box-sizing: border-box; }
    body { margin: 0; }
    .edl {
      --bg: #faf7f1; --panel: #ffffff; --raised: #fdfbf7;
      --ink: #1b1812; --dim: #6f685c; --faint: #9a9384;
      --border: #e7e1d5; --rule: #d8d0c1; --accent: #b1431e; --accenttext: #8f3517;
    }
    .edl[data-theme="dark"] {
      --bg: #14120d; --panel: #1c1912; --raised: #211d15;
      --ink: #efe9dd; --dim: #a59d8e; --faint: #7c7567;
      --border: #2c271d; --rule: #353026; --accent: #e08152; --accenttext: #e69468;
    }
    .edl ::selection { background: var(--accent); color: #fff; }
    .edl-lede::first-letter { font-size: 3.3em; line-height: .82; float: left; padding: 8px 10px 0 0; font-family: 'Newsreader', serif; font-weight: 600; color: var(--accent); }
    @keyframes edlslide { from { transform: translateX(40px); opacity: 0; } to { transform: none; opacity: 1; } }
    .ecard { transition: box-shadow .2s, transform .2s; }
    .ecard:hover { box-shadow: 0 14px 40px -18px rgba(60,40,20,.4); transform: translateY(-3px); }
    .ebtn { transition: background .15s, color .15s, border-color .15s; cursor: pointer; }
    .ebtn:hover { background: var(--ink) !important; color: var(--panel) !important; border-color: var(--ink) !important; }
    .elink { transition: color .15s; cursor: pointer; }
    .elink:hover { color: var(--accent) !important; }
    .efilter { cursor: pointer; transition: color .15s; background: none; border: none; font-family: inherit; }
    .erow:hover { background: var(--raised) !important; }
    .escroll::-webkit-scrollbar { width: 9px; height: 9px; }
    .escroll::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 6px; }
    .hidden { display: none !important; }
  </style>
</body>
</html>
