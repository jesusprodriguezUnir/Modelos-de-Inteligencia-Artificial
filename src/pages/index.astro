---
import Layout from '../layouts/Layout.astro';
import { models, companies } from '../data/models';
import type { Model } from '../data/types';

// Orden de empresas: US primero (las grandes), luego EU, luego China, luego Open.
const originRank: Record<string, number> = { US: 0, EU: 1, China: 2, Open: 3 };
const companyOrder = Object.keys(companies).sort((a, b) => {
  const oa = originRank[companies[a].origin] ?? 9;
  const ob = originRank[companies[b].origin] ?? 9;
  if (oa !== ob) return oa - ob;
  return a.localeCompare(b);
});

const grouped = companyOrder
  .map((c) => ({ company: c, meta: companies[c], items: models.filter((m) => m.company === c) }))
  .filter((g) => g.items.length > 0);

const fmtPrice = (m: Model) => {
  const p = m.pricing;
  if (p.inputPer1M == null) return { main: '—', out: '', sub: p.note ?? '' };
  return {
    main: `$${p.inputPer1M}`,
    out: p.outputPer1M != null ? `/ $${p.outputPer1M} out` : '',
    sub: (p.approx ? 'aprox. ' : '') + 'por 1M tok',
  };
};
const fmtCtx = (n: number | null) => (n == null ? '—' : n >= 1_000_000 ? `${n / 1_000_000}M` : `${Math.round(n / 1000)}K`);

const catLabels: Record<string, string> = {
  coding: 'Código', reasoning: 'Razonamiento', agentic: 'Agéntico', general: 'General',
  multimodal: 'Multimodal', fast: 'Rápido', budget: 'Económico', tool: 'Herramienta',
};
const originLabels: Record<string, string> = { US: 'EE. UU.', EU: 'Europa', China: 'China', Open: 'Open' };

const allCats = ['coding', 'reasoning', 'agentic', 'multimodal', 'fast', 'budget'];
const allOrigins = ['US', 'EU', 'China', 'Open'];
const totalModels = models.filter((m) => m.kind === 'model').length;
const totalTools = models.filter((m) => m.kind === 'tool').length;

// Determinar modelos "nuevos" (últimos 60 días)
const now = new Date();
const isNew = (m: Model) => {
  if (!m.releaseDate) return false;
  const rd = new Date(m.releaseDate);
  return (now.getTime() - rd.getTime()) < 60 * 24 * 60 * 60 * 1000;
};

// Rankings rápidos por caso de uso (solo modelos, no tools)
const justModels = models.filter((m) => m.kind === 'model');
const topCoding = justModels.filter((m) => m.category.includes('coding')).slice(0, 3);
const topReasoning = justModels.filter((m) => m.category.includes('reasoning')).slice(0, 3);
const topBudget = justModels.filter((m) => m.category.includes('budget')).sort((a, b) => (a.pricing.inputPer1M ?? 99) - (b.pricing.inputPer1M ?? 99)).slice(0, 3);
const topAgentic = justModels.filter((m) => m.category.includes('agentic')).slice(0, 3);

const rankings = [
  { icon: '💻', label: 'Código', items: topCoding },
  { icon: '🧠', label: 'Razonamiento', items: topReasoning },
  { icon: '🤖', label: 'Agéntico', items: topAgentic },
  { icon: '💰', label: 'Económico', items: topBudget },
];
---

<Layout>
  <header class="hero">
    <div class="wrap">
      <h1>Modelos de IA para Programación</h1>
      <p>Catálogo comparativo de los modelos actuales agrupados por empresa: precios, contexto, ejemplos de uso, acceso a playgrounds y vídeos de referencia.</p>
      <div class="hero-links">
        <a href="./local.html" class="guide-link">🖥️ Guía: modelos locales →</a>
        <a href="./tools.html" class="guide-link">🛠️ Comparador de herramientas →</a>
        <a href="./benchmarks.html" class="guide-link">📊 Tabla de benchmarks →</a>
      </div>
      <div class="stats">
        <div class="stat"><b>{totalModels}</b><span>modelos</span></div>
        <div class="stat"><b>{totalTools}</b><span>herramientas</span></div>
        <div class="stat"><b>{grouped.length}</b><span>proveedores</span></div>
        <div class="stat"><b>Jun 2026</b><span>datos actualizados</span></div>
      </div>
      <p class="disclaimer">⚠️ Los precios y especificaciones cambian con frecuencia. Confirma siempre en la página oficial de cada modelo (botón «Docs») antes de presupuestar. Algunos precios marcados como «aprox.» están pendientes de confirmación.</p>
    </div>
  </header>

  <!-- Ranking rápido por caso de uso -->
  <section class="rankings-section">
    <div class="wrap">
      <h2 class="rankings-title">🏆 Top por caso de uso</h2>
      <div class="rankings-grid">
        {rankings.map((r) => (
          <div class="ranking-card">
            <div class="ranking-header">
              <span class="ranking-icon">{r.icon}</span>
              <span class="ranking-label">{r.label}</span>
            </div>
            <ol class="ranking-list">
              {r.items.map((m, i) => (
                <li data-id={m.id} class="ranking-item">
                  <span class="ranking-pos">{i + 1}</span>
                  <span class="ranking-dot" style={`background:${companies[m.company].accent}`}></span>
                  <span class="ranking-name">{m.displayName}</span>
                  {m.pricing.inputPer1M != null && <span class="ranking-price">${m.pricing.inputPer1M}/M</span>}
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="toolbar">
    <div class="wrap">
      <div class="toolbar-row">
        <div class="search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          <input type="search" id="search" placeholder="Buscar modelo, empresa, API string..." autocomplete="off" />
        </div>
        <div class="view-toggle">
          <button data-view="grid" class="active">Tarjetas</button>
          <button data-view="table">Tabla</button>
        </div>
      </div>
      <div class="toolbar-row" style="margin-top:12px">
        <div class="chips" id="origin-chips">
          <span class="chip active" data-origin="all">Todos</span>
          {allOrigins.map((o) => <span class="chip" data-origin={o}>{originLabels[o]}</span>)}
        </div>
        <div class="chips" id="cat-chips">
          {allCats.map((c) => <span class="chip" data-cat={c}>{catLabels[c]}</span>)}
        </div>
      </div>
    </div>
  </div>

  <main class="wrap">
    <!-- Vista tarjetas -->
    <div id="grid-view">
      {grouped.map((g) => (
        <section class="company" data-company-section={g.company}>
          <div class="company-head">
            <span class="company-dot" style={`background:${g.meta.accent}`}></span>
            <h2>{g.meta.name}</h2>
            <span class="origin">{originLabels[g.meta.origin]}</span>
            <span class="blurb">{g.meta.blurb}</span>
          </div>
          <div class="grid">
            {g.items.map((m) => {
              const p = fmtPrice(m);
              const hasVideo = (m.videos?.length ?? 0) > 0;
              const mIsNew = isNew(m);
              return (
                <article
                  class="card"
                  data-id={m.id}
                  data-name={m.displayName.toLowerCase()}
                  data-company={m.company.toLowerCase()}
                  data-api={(m.apiModelString ?? '').toLowerCase()}
                  data-origin={m.origin}
                  data-cats={m.category.join(' ')}
                  style={`--accent:${g.meta.accent}`}
                >
                  {/* Badges */}
                  <div class="card-badges">
                    {mIsNew && <span class="badge-new">🆕 Nuevo</span>}
                    {hasVideo && <span class="badge-video" title="Tiene vídeos de referencia">▶</span>}
                  </div>
                  <div class="card-top">
                    <div>
                      <div class="company-name">{m.company}</div>
                      <h3>{m.displayName}</h3>
                    </div>
                    <div class="price">
                      <b>{p.main}</b> <span class="out">{p.out}</span>
                      <div class="sub">{p.sub}</div>
                    </div>
                  </div>
                  <div class="ctx">Contexto: <b style="color:var(--text)">{fmtCtx(m.context)}</b> tok · {m.modalities.join(', ')}</div>
                  {m.releaseDate && <div class="release-date">📅 {m.releaseDate}</div>}
                  <div class="meta">
                    {m.openWeight && <span class="tag ow">open-weight</span>}
                    {m.license && <span class="tag license">{m.license}</span>}
                    {m.category.slice(0, 3).map((c) => <span class="tag">{catLabels[c]}</span>)}
                  </div>
                  <div class="cmp">
                    <label onclick="event.stopPropagation()">
                      <input type="checkbox" class="cmp-check" data-id={m.id} /> comparar
                    </label>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}
      <div class="empty hidden" id="empty-grid">Sin resultados con los filtros actuales.</div>
    </div>

    <!-- Vista tabla -->
    <div id="table-view" class="hidden">
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Modelo</th><th>Empresa</th><th>Origen</th><th>Entrada $/1M</th><th>Salida $/1M</th><th>Contexto</th><th>Categorías</th><th>🎬</th></tr>
          </thead>
          <tbody id="table-body">
            {models.map((m) => (
              <tr
                data-id={m.id}
                data-name={m.displayName.toLowerCase()}
                data-company={m.company.toLowerCase()}
                data-api={(m.apiModelString ?? '').toLowerCase()}
                data-origin={m.origin}
                data-cats={m.category.join(' ')}
              >
                <td>
                  <span class="dot" style={`background:${companies[m.company].accent}`}></span>
                  {m.displayName}
                  {isNew(m) && <span class="table-badge-new">nuevo</span>}
                </td>
                <td>{m.company}</td>
                <td>{originLabels[m.origin]}</td>
                <td>{m.pricing.inputPer1M ?? '—'}</td>
                <td>{m.pricing.outputPer1M ?? '—'}</td>
                <td>{fmtCtx(m.context)}</td>
                <td>{m.category.map((c) => catLabels[c]).join(', ')}</td>
                <td>{(m.videos?.length ?? 0) > 0 ? '▶' : ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="empty hidden" id="empty-table">Sin resultados con los filtros actuales.</div>
    </div>
  </main>

  <footer>
    <div class="wrap">
      Catálogo estático generado con Astro · Datos a junio de 2026 · Edita <code>src/data/models.ts</code> para añadir o actualizar modelos.
    </div>
  </footer>

  <!-- Modal de detalle -->
  <div class="modal-bg" id="modal-bg"></div>
  <div class="modal" id="modal">
    <div class="modal-head"><div class="bar" id="modal-bar"></div>
      <button class="modal-close" id="modal-close">×</button>
      <div class="sub" id="modal-company"></div>
      <h2 id="modal-title"></h2>
      <div class="sub" id="modal-notes"></div>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>

  <!-- Barra del comparador -->
  <div class="compare-bar" id="compare-bar">
    <div class="compare-inner">
      <span class="count" id="compare-count">0 seleccionados</span>
      <div class="compare-chips" id="compare-chips"></div>
      <button class="btn" id="compare-clear">Limpiar</button>
      <button class="btn primary" id="compare-open">Comparar</button>
    </div>
  </div>

  <!-- Datos para el cliente -->
  <script type="application/json" id="model-data" is:inline set:html={JSON.stringify({ models, companies, catLabels, originLabels })}></script>

  <script>
    const DATA = JSON.parse(document.getElementById('model-data').textContent);
    const byId = Object.fromEntries(DATA.models.map((m) => [m.id, m]));
    const C = DATA.companies, CAT = DATA.catLabels, ORI = DATA.originLabels;

    const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const fmtCtx = (n) => n == null ? '—' : n >= 1e6 ? `${n / 1e6}M` : `${Math.round(n / 1000)}K`;

    // Helper: extraer YouTube video ID de URL
    function ytVideoId(url) {
      if (!url) return null;
      const m = url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      return m ? m[1] : null;
    }

    // ── Ranking items → abrir modal ─────────────────────
    document.querySelectorAll('.ranking-item').forEach((el) => {
      el.addEventListener('click', () => openModal(el.dataset.id));
    });

    // ── Filtros / búsqueda ──────────────────────────────
    let q = '', origin = 'all', cats = new Set();

    function matches(el) {
      if (q && !(el.dataset.name + ' ' + el.dataset.company + ' ' + el.dataset.api).includes(q)) return false;
      if (origin !== 'all' && el.dataset.origin !== origin) return false;
      if (cats.size) { const has = el.dataset.cats.split(' '); for (const c of cats) if (!has.includes(c)) return false; }
      return true;
    }

    function applyFilters() {
      // Tarjetas
      let gridShown = 0;
      document.querySelectorAll('#grid-view .card').forEach((el) => {
        const ok = matches(el); el.classList.toggle('hidden', !ok); if (ok) gridShown++;
      });
      document.querySelectorAll('#grid-view .company').forEach((sec) => {
        const any = sec.querySelectorAll('.card:not(.hidden)').length > 0;
        sec.classList.toggle('hidden', !any);
      });
      document.getElementById('empty-grid').classList.toggle('hidden', gridShown > 0);
      // Tabla
      let tShown = 0;
      document.querySelectorAll('#table-body tr').forEach((el) => {
        const ok = matches(el); el.classList.toggle('hidden', !ok); if (ok) tShown++;
      });
      document.getElementById('empty-table').classList.toggle('hidden', tShown > 0);
    }

    document.getElementById('search').addEventListener('input', (e) => { q = e.target.value.toLowerCase().trim(); applyFilters(); });

    document.getElementById('origin-chips').addEventListener('click', (e) => {
      const chip = e.target.closest('.chip'); if (!chip) return;
      origin = chip.dataset.origin;
      document.querySelectorAll('#origin-chips .chip').forEach((c) => c.classList.toggle('active', c === chip));
      applyFilters();
    });

    document.getElementById('cat-chips').addEventListener('click', (e) => {
      const chip = e.target.closest('.chip'); if (!chip) return;
      const c = chip.dataset.cat;
      if (cats.has(c)) cats.delete(c); else cats.add(c);
      chip.classList.toggle('active');
      applyFilters();
    });

    // ── Cambio de vista ─────────────────────────────────
    document.querySelector('.view-toggle').addEventListener('click', (e) => {
      const btn = e.target.closest('button'); if (!btn) return;
      document.querySelectorAll('.view-toggle button').forEach((b) => b.classList.toggle('active', b === btn));
      const grid = btn.dataset.view === 'grid';
      document.getElementById('grid-view').classList.toggle('hidden', !grid);
      document.getElementById('table-view').classList.toggle('hidden', grid);
    });

    // ── Modal de detalle ────────────────────────────────
    const modal = document.getElementById('modal'), modalBg = document.getElementById('modal-bg');

    function codeBlock(ex) {
      return `<div class="code-title">${esc(ex.title)} · ${esc(ex.lang)}</div>
        <div class="code-block"><button class="copy" data-code="${esc(ex.code)}">Copiar</button>
        <pre><code class="language-${esc(ex.lang)}">${esc(ex.code)}</code></pre></div>`;
    }

    function openModal(id) {
      const m = byId[id]; if (!m) return;
      const accent = C[m.company].accent;
      document.getElementById('modal-bar').style.background = accent;
      document.getElementById('modal-company').textContent = `${m.company} · ${ORI[m.origin]}`;
      document.getElementById('modal-title').textContent = m.displayName;
      document.getElementById('modal-notes').textContent = m.notes || '';

      const p = m.pricing;
      const priceTxt = p.inputPer1M == null
        ? (p.note || '—')
        : `$${p.inputPer1M} entrada · ${p.outputPer1M != null ? '$' + p.outputPer1M + ' salida' : '—'} (por 1M tok)${p.approx ? ' · aprox.' : ''}`;

      let html = `<div class="kv">
        <div><div class="k">Precio</div><div class="v" style="font-size:14px">${esc(priceTxt)}</div></div>
        <div><div class="k">Contexto</div><div class="v">${fmtCtx(m.context)} tok</div></div>
        <div><div class="k">Modalidades</div><div class="v" style="font-size:14px">${m.modalities.join(', ')}</div></div>
        ${m.releaseDate ? `<div><div class="k">Lanzamiento</div><div class="v" style="font-size:14px">${esc(m.releaseDate)}</div></div>` : ''}
        ${m.apiModelString ? `<div><div class="k">API model</div><div class="v mono" style="font-size:13px">${esc(m.apiModelString)}</div></div>` : ''}
        <div><div class="k">Categorías</div><div class="v" style="font-size:14px">${m.category.map((c) => CAT[c]).join(', ')}</div></div>
        ${m.parameters ? `<div><div class="k">Parámetros</div><div class="v" style="font-size:14px">${m.parameters}B</div></div>` : ''}
        ${m.license ? `<div><div class="k">Licencia</div><div class="v" style="font-size:14px">${esc(m.license)}</div></div>` : ''}
      </div>`;

      // Benchmarks
      if (m.benchmarks) {
        const b = m.benchmarks;
        html += `<div class="section-title">📊 Benchmarks</div><div class="benchmarks-grid">`;
        if (b.sweBenchPro != null) html += `<div class="bench-item"><div class="bench-label">SWE-bench Pro</div><div class="bench-bar"><div class="bench-fill" style="width:${b.sweBenchPro}%;background:${accent}"></div></div><div class="bench-val">${b.sweBenchPro}%</div></div>`;
        if (b.humanEval != null) html += `<div class="bench-item"><div class="bench-label">HumanEval</div><div class="bench-bar"><div class="bench-fill" style="width:${b.humanEval}%;background:${accent}"></div></div><div class="bench-val">${b.humanEval}%</div></div>`;
        if (b.liveCodeBench != null) html += `<div class="bench-item"><div class="bench-label">LiveCodeBench</div><div class="bench-bar"><div class="bench-fill" style="width:${b.liveCodeBench}%;background:${accent}"></div></div><div class="bench-val">${b.liveCodeBench}%</div></div>`;
        html += `</div>`;
      }

      html += `<div class="btn-row">`;
      if (m.playgroundUrl) html += `<a class="btn primary" href="${esc(m.playgroundUrl)}" target="_blank" rel="noopener">▶ Playground</a>`;
      if (m.docsUrl) html += `<a class="btn" href="${esc(m.docsUrl)}" target="_blank" rel="noopener">📄 Docs / Pricing</a>`;
      html += `</div>`;

      if (m.examples?.length) {
        html += `<div class="section-title">Ejemplo de uso</div>`;
        m.examples.forEach((ex) => { html += codeBlock(ex); });
      }

      // Vídeos con embed
      if (m.videos?.length) {
        html += `<div class="section-title">🎬 Vídeos de referencia</div>`;
        m.videos.forEach((v) => {
          const vid = ytVideoId(v.url);
          if (vid) {
            // Embed de YouTube
            html += `<div class="video-embed">
              <div class="video-embed-title">${esc(v.title)}${v.source ? ` · ${esc(v.source)}` : ''}</div>
              <div class="video-ratio">
                <iframe src="https://www.youtube.com/embed/${vid}" title="${esc(v.title)}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
              </div>
            </div>`;
          } else {
            // Enlace normal (búsqueda u otro)
            html += `<a class="video-link" href="${esc(v.url)}" target="_blank" rel="noopener">
              <span class="play">▶</span><span>${esc(v.title)}${v.source ? ` · ${esc(v.source)}` : ''}</span></a>`;
          }
        });
      }

      document.getElementById('modal-body').innerHTML = html;
      modal.classList.add('open'); modalBg.classList.add('open');
      if (window.hljs) document.querySelectorAll('#modal-body pre code').forEach((b) => window.hljs.highlightElement(b));
    }

    function closeModal() { modal.classList.remove('open'); modalBg.classList.remove('open'); }
    document.getElementById('modal-close').addEventListener('click', closeModal);
    modalBg.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    document.querySelectorAll('#grid-view .card').forEach((c) => c.addEventListener('click', () => openModal(c.dataset.id)));
    document.querySelectorAll('#table-body tr').forEach((r) => r.addEventListener('click', () => openModal(r.dataset.id)));

    // Copiar código (delegado)
    document.getElementById('modal-body').addEventListener('click', (e) => {
      const b = e.target.closest('.copy'); if (!b) return;
      navigator.clipboard.writeText(b.dataset.code).then(() => { const t = b.textContent; b.textContent = '¡Copiado!'; setTimeout(() => b.textContent = t, 1200); });
    });

    // ── Comparador ──────────────────────────────────────
    const selected = new Set();
    const bar = document.getElementById('compare-bar');

    function renderCompareBar() {
      document.getElementById('compare-count').textContent = `${selected.size} seleccionado${selected.size === 1 ? '' : 's'}`;
      const chips = document.getElementById('compare-chips');
      chips.innerHTML = [...selected].map((id) => `<span class="cc">${esc(byId[id].displayName)}<button data-id="${id}">×</button></span>`).join('');
      bar.classList.toggle('show', selected.size > 0);
    }

    document.querySelectorAll('.cmp-check').forEach((chk) => chk.addEventListener('change', () => {
      const id = chk.dataset.id;
      if (chk.checked) { if (selected.size >= 4) { chk.checked = false; alert('Máximo 4 modelos para comparar.'); return; } selected.add(id); }
      else selected.delete(id);
      renderCompareBar();
    }));

    document.getElementById('compare-chips').addEventListener('click', (e) => {
      const b = e.target.closest('button'); if (!b) return;
      selected.delete(b.dataset.id);
      document.querySelectorAll(`.cmp-check[data-id="${b.dataset.id}"]`).forEach((c) => c.checked = false);
      renderCompareBar();
    });

    document.getElementById('compare-clear').addEventListener('click', () => {
      selected.clear(); document.querySelectorAll('.cmp-check').forEach((c) => c.checked = false); renderCompareBar();
    });

    document.getElementById('compare-open').addEventListener('click', () => {
      if (!selected.size) return;
      const ms = [...selected].map((id) => byId[id]);
      const row = (label, fn) => `<tr><th>${label}</th>${ms.map((m) => `<td>${fn(m)}</td>`).join('')}</tr>`;
      const price = (m) => m.pricing.inputPer1M == null ? esc(m.pricing.note || '—')
        : `$${m.pricing.inputPer1M} / $${m.pricing.outputPer1M ?? '—'}${m.pricing.approx ? ' (aprox.)' : ''}`;
      let html = `<div class="table-wrap"><table class="cmp-table"><thead><tr><th>Característica</th>${ms.map((m) => `<th><span class="dot" style="background:${C[m.company].accent}"></span>${esc(m.displayName)}</th>`).join('')}</tr></thead><tbody>`;
      html += row('Empresa', (m) => esc(m.company));
      html += row('Origen', (m) => ORI[m.origin]);
      html += row('Precio $/1M (in/out)', price);
      html += row('Contexto', (m) => fmtCtx(m.context) + ' tok');
      html += row('Modalidades', (m) => m.modalities.join(', '));
      html += row('Open-weight', (m) => m.openWeight ? '✓' : '—');
      html += row('Licencia', (m) => m.license ? esc(m.license) : '—');
      html += row('Parámetros', (m) => m.parameters ? `${m.parameters}B` : '—');
      html += row('SWE-bench Pro', (m) => m.benchmarks?.sweBenchPro ? `${m.benchmarks.sweBenchPro}%` : '—');
      html += row('Categorías', (m) => m.category.map((c) => CAT[c]).join(', '));
      html += row('API string', (m) => m.apiModelString ? `<span class="mono">${esc(m.apiModelString)}</span>` : '—');
      html += row('Playground', (m) => m.playgroundUrl ? `<a href="${esc(m.playgroundUrl)}" target="_blank" rel="noopener">abrir</a>` : '—');
      html += `</tbody></table></div>`;

      document.getElementById('modal-bar').style.background = 'var(--brand)';
      document.getElementById('modal-company').textContent = 'Comparador';
      document.getElementById('modal-title').textContent = `${ms.length} modelos`;
      document.getElementById('modal-notes').textContent = '';
      document.getElementById('modal-body').innerHTML = html;
      modal.classList.add('open'); modalBg.classList.add('open');
    });
  </script>
</Layout>
