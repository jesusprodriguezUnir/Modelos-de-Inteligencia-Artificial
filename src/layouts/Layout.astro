---
interface Props {
  title?: string;
  /** Clave de página para resaltar el enlace activo de la barra superior. */
  active?: 'index' | 'local' | 'tools' | 'opencode' | 'benchmarks';
}
const { title = 'Catálogo de Modelos de IA para Programación', active } = Astro.props;

const nav = [
  { key: 'index', label: 'Catálogo', href: './index.html' },
  { key: 'local', label: 'Locales', href: './local.html' },
  { key: 'tools', label: 'Herramientas', href: './tools.html' },
  { key: 'opencode', label: 'Guía OpenCode', href: './opencode.html' },
  { key: 'benchmarks', label: 'Benchmarks', href: './benchmarks.html' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Catálogo de modelos de IA para programación agrupados por empresa: precios, contexto, ejemplos de uso, playgrounds y vídeos." />
    <title>{title}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧩</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Resaltado de código (estático, vía CDN) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
    <!-- Fijar el tema antes del primer paint para evitar parpadeo -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('dsh-theme') || 'dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body class="dsh-scroll">
    <header class="topbar">
      <a href="./index.html" class="brand">
        <span class="brand-logo"></span>
        <span class="brand-name">AI Models</span>
        <span class="brand-badge">panel · 2026.06</span>
      </a>
      <nav class="topnav">
        {nav.map((n) => (
          <a href={n.href} class:list={['topnav-link', { active: n.key === active }]}>{n.label}</a>
        ))}
      </nav>
      <button id="theme-toggle" class="dbtn theme-toggle" type="button" aria-label="Cambiar tema">☀ Claro</button>
    </header>

    <slot />

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        function label() {
          var dark = document.documentElement.getAttribute('data-theme') === 'dark';
          if (btn) btn.textContent = dark ? '☀ Claro' : '☾ Oscuro';
        }
        label();
        if (btn) {
          btn.addEventListener('click', function () {
            var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try { localStorage.setItem('dsh-theme', next); } catch (e) {}
            label();
            // Notificar a la página (p. ej. el catálogo recolorea barras inline)
            window.dispatchEvent(new CustomEvent('themechange', { detail: next }));
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ── Tokens del sistema Dashboard ──────────────────────────────── */
  :root,
  html[data-theme='dark'] {
    --bg: #0a0a12; --panel: #13131f; --panel2: #181826; --raised: #1e1e2e;
    --border: #242438; --border2: #303049; --text: #c7cae0; --head: #f1f2fb;
    --dim: #797d9a; --accent: #8b7bff; --accent2: #22d3ee; --pos: #34d399; --warn: #fbbf24;

    /* Aliases heredados (usados por las páginas de guías) */
    --bg-elev: var(--panel); --bg-elev-2: var(--panel2);
    --text-faint: var(--dim); --brand: var(--accent); --brand-2: var(--accent2);
    --ok: var(--pos);
    --radius: 12px; --shadow: 0 12px 32px -16px rgba(120, 100, 255, 0.4); --maxw: 1280px;
  }
  html[data-theme='light'] {
    --bg: #f3f4fb; --panel: #ffffff; --panel2: #f7f8fd; --raised: #eef0f9;
    --border: #e4e6f1; --border2: #d4d7e8; --text: #2c2f42; --head: #12141d;
    --dim: #6a6e87; --accent: #6d4dff; --accent2: #0a93b0; --pos: #0d9f6e; --warn: #d97706;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Space Grotesk', -apple-system, system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  code, pre, .mono { font-family: 'IBM Plex Mono', ui-monospace, monospace; }

  ::selection { background: var(--accent); color: #fff; }
  .dsh-scroll::-webkit-scrollbar { width: 9px; height: 9px; }
  .dsh-scroll::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 6px; }

  @keyframes dshslide { from { transform: translateX(40px); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes growbar { from { width: 0 !important; } }

  /* ── Clases del sistema (hovers) ───────────────────────────────── */
  .dcard { transition: border-color .15s, transform .15s, box-shadow .15s; }
  .dcard:hover { border-color: var(--accent) !important; transform: translateY(-2px); box-shadow: var(--shadow); }
  .dbtn { transition: all .13s; cursor: pointer; }
  .dbtn:hover { filter: brightness(1.12); }
  .dpill { cursor: pointer; transition: all .13s; }
  .dlink { transition: color .15s; }
  .dlink:hover { color: var(--accent) !important; }
  .drow:hover { background: var(--panel2) !important; }
  .hidden { display: none !important; }

  /* ── Barra superior compartida ─────────────────────────────────── */
  .topbar {
    position: sticky; top: 0; z-index: 40;
    background: var(--panel); border-bottom: 1px solid var(--border);
    padding: 11px 22px; display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
  }
  .brand { display: flex; align-items: center; gap: 10px; }
  .brand:hover { text-decoration: none; }
  .brand-logo { width: 24px; height: 24px; border-radius: 6px; background: linear-gradient(135deg, var(--accent), var(--accent2)); display: inline-block; }
  .brand-name { font-weight: 700; font-size: 16px; color: var(--head); letter-spacing: -.3px; }
  .brand-badge { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--dim); border: 1px solid var(--border2); border-radius: 4px; padding: 1px 7px; }
  .topnav { display: flex; gap: 6px; flex-wrap: wrap; margin-left: 6px; }
  .topnav-link {
    font-size: 13px; color: var(--text); padding: 6px 11px; border-radius: 8px;
    border: 1px solid transparent; transition: all .13s;
  }
  .topnav-link:hover { text-decoration: none; background: var(--panel2); color: var(--head); }
  .topnav-link.active { background: var(--panel2); border-color: var(--border2); color: var(--head); font-weight: 600; }
  .theme-toggle {
    margin-left: auto; background: var(--panel2); color: var(--text);
    border: 1px solid var(--border2); padding: 6px 12px; font-family: inherit;
    font-size: 12px; border-radius: 8px;
  }

  /* ── Layout de contenido (guías) ───────────────────────────────── */
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 22px; }

  .hero { padding: 40px 0 26px; }
  .hero h1 { font-size: clamp(26px, 4vw, 40px); font-weight: 700; letter-spacing: -.02em; margin: 0 0 12px; color: var(--head); }
  .hero p { color: var(--text); font-size: 16px; max-width: 720px; margin: 0 0 8px; }
  .disclaimer { margin-top: 18px; font-size: 13px; color: var(--dim); border-left: 2px solid var(--border2); padding-left: 12px; }
  .back { display: inline-block; margin-bottom: 16px; font-size: 13px; color: var(--dim); }

  /* ── Botones ───────────────────────────────────────────────────── */
  .btn {
    display: inline-flex; align-items: center; gap: 7px; padding: 9px 15px; border-radius: 9px;
    font-size: 14px; font-weight: 600; border: 1px solid var(--border2);
    background: var(--panel2); color: var(--text); cursor: pointer;
  }
  .btn.primary { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #fff; border-color: transparent; }
  .btn:hover { filter: brightness(1.1); text-decoration: none; }

  /* ── Tablas ────────────────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; margin-top: 16px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--panel); }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); white-space: nowrap; }
  th { color: var(--dim); font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: .6px; }
  td .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 9px; vertical-align: middle; }

  /* ── Tags / vídeos / código ────────────────────────────────────── */
  .tag { font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 6px; background: var(--panel2); color: var(--text); border: 1px solid var(--border); }
  .empty { text-align: center; color: var(--dim); padding: 60px 0; }

  .video-link { display: flex; align-items: center; gap: 11px; padding: 10px 13px; border: 1px solid var(--border); border-radius: 9px; margin-bottom: 8px; background: var(--panel2); transition: border-color .15s; }
  .video-link:hover { border-color: var(--accent); text-decoration: none; }
  .video-link .play { width: 32px; height: 32px; border-radius: 8px; background: rgba(34, 211, 238, .15); color: var(--accent2); display: grid; place-items: center; flex: none; }

  pre { margin: 0; border-radius: 10px; overflow-x: auto; font-size: 13px; border: 1px solid var(--border); }
  pre code { padding: 14px !important; display: block; }

  footer { border-top: 1px solid var(--border); margin-top: 60px; padding: 28px 0; color: var(--dim); font-size: 13px; }

  @media (max-width: 640px) {
    .hero { padding: 30px 0 20px; }
    .brand-badge { display: none; }
  }
</style>
