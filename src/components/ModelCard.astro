---
// Tarjeta de modelo del catálogo Dashboard. Recibe un modelo ya "decorado"
// (ver decorate() en index.astro) con porcentajes de barra precalculados.
interface Props {
  m: any;
}
const { m } = Astro.props;
---
<div
  class="dcard"
  data-id={m.id}
  data-name={m.displayName.toLowerCase()}
  data-company={m.company.toLowerCase()}
  data-api={(m.apiModelString ?? '').toLowerCase()}
  data-notes={(m.notes ?? '').toLowerCase()}
  data-origin={m.origin}
  data-cats={m.categoryKeys.join(' ')}
  data-kind={m.kind}
  data-pop={m.popularity}
  data-tier={m.tierKey}
  style="background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg); padding:var(--space-5);"
>
  <div style="display:flex; align-items:center; gap:var(--space-2);">
    <span style={`width:9px; height:9px; border-radius:50%; background:${m.accent};`}></span>
    <span style="font-size:var(--fs-xs); letter-spacing:.5px; text-transform:uppercase; color:var(--dim);">{m.companyName}</span>
    <span style="margin-left:auto; font-size:var(--fs-xs); color:var(--dim); background:var(--panel2); border-radius:var(--radius-sm); padding:var(--space-1) var(--space-2);">{m.kindLabel}</span>
  </div>
  <div style="display:flex; align-items:baseline; gap:var(--space-2); margin-top:var(--space-3);">
    <h3 style="margin:0; font-size:var(--fs-2xl); font-weight:600; color:var(--head);">{m.displayName}</h3>
  </div>
  <div style="font-family:'IBM Plex Mono',monospace; font-size:var(--fs-xs); color:var(--accent); min-height:15px;">{m.api}</div>

  <!-- barras métricas -->
  <div style="display:flex; flex-direction:column; gap:var(--space-3); margin-top:var(--space-4);">
    <div style="display:flex; align-items:center; gap:var(--space-3);">
      <span style="width:54px; flex:none; font-size:var(--fs-xs); color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">In/1M</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:var(--radius-xs); overflow:hidden;"><span style={`display:block; height:100%; width:${m.barInPct}; background:var(--accent2); border-radius:var(--radius-xs);`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:var(--fs-base); color:var(--head);">{m.priceInText}</span>
    </div>
    <div style="display:flex; align-items:center; gap:var(--space-3);">
      <span style="width:54px; flex:none; font-size:var(--fs-xs); color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">Out/1M</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:var(--radius-xs); overflow:hidden;"><span style={`display:block; height:100%; width:${m.barOutPct}; background:var(--accent); border-radius:var(--radius-xs);`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:var(--fs-base); color:var(--head);">{m.priceOutText}</span>
    </div>
    <div style="display:flex; align-items:center; gap:var(--space-3);">
      <span style="width:54px; flex:none; font-size:var(--fs-xs); color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">Contexto</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:var(--radius-xs); overflow:hidden;"><span style={`display:block; height:100%; width:${m.barCtxPct}; background:var(--warn); border-radius:var(--radius-xs);`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:var(--fs-base); color:var(--head);">{m.contextText}</span>
    </div>
    {m.swe != null && (
      <div style="display:flex; align-items:center; gap:var(--space-3);">
        <span style="width:54px; flex:none; font-size:var(--fs-xs); color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">SWE</span>
        <div style="flex:1; height:8px; background:var(--panel2); border-radius:var(--radius-xs); overflow:hidden;"><span style={`display:block; height:100%; width:${m.barSwePct}; background:var(--pos); border-radius:var(--radius-xs);`}></span></div>
        <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:var(--fs-base); color:var(--pos);">{m.sweText}</span>
      </div>
    )}
  </div>

  <div style="display:flex; flex-wrap:wrap; gap:var(--space-1); margin-top:var(--space-4);">
    <span style="font-size:var(--fs-base-lg); color:var(--text); background:var(--panel2); border-radius:var(--radius-sm); padding:var(--space-1) var(--space-2);">{m.originLabel}</span>
    {m.cats.map((cat: string) => (
      <span style="font-size:var(--fs-base-lg); color:var(--dim); background:var(--panel2); border-radius:var(--radius-sm); padding:var(--space-1) var(--space-2);">{cat}</span>
    ))}
    {m.openWeight && <span style="font-size:var(--fs-base-lg); color:var(--pos); border:1px solid var(--pos); border-radius:var(--radius-sm); padding:var(--space-1) var(--space-2);">open</span>}
  </div>

  <div style="display:flex; gap:var(--space-2); margin-top:var(--space-4);">
    <button class="dbtn" data-action="detail" data-id={m.id} type="button" aria-label={`Ver detalles de ${m.displayName}`} style="flex:1; font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2); border-radius:var(--radius-md); border:none; background:var(--accent); color:#fff; font-weight:500;">Ver detalle</button>
    <button class="dbtn" data-action="compare" data-id={m.id} type="button" aria-label={`Comparar ${m.displayName}`} style="font-family:inherit; font-size:var(--fs-base-lg); padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); border:1px solid var(--border2); background:transparent; color:var(--dim);">+</button>
  </div>
</div>
