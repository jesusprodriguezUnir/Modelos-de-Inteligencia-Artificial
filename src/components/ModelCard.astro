---
// Tarjeta de modelo del catálogo Dashboard. Recibe un modelo ya "decorado"
// (ver decorate() en index.astro) con porcentajes de barra precalculados.
interface Props {
  m: any;
}
const { m } = Astro.props;
---
<div
  class="dcard"
  data-id={m.id}
  data-name={m.displayName.toLowerCase()}
  data-company={m.company.toLowerCase()}
  data-api={(m.apiModelString ?? '').toLowerCase()}
  data-notes={(m.notes ?? '').toLowerCase()}
  data-origin={m.origin}
  data-cats={m.categoryKeys.join(' ')}
  data-kind={m.kind}
  data-pop={m.popularity}
  data-tier={m.tierKey}
  style="background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:17px;"
>
  <div style="display:flex; align-items:center; gap:8px;">
    <span style={`width:9px; height:9px; border-radius:50%; background:${m.accent};`}></span>
    <span style="font-size:11px; letter-spacing:.5px; text-transform:uppercase; color:var(--dim);">{m.companyName}</span>
    <span style="margin-left:auto; font-size:10px; color:var(--dim); background:var(--panel2); border-radius:5px; padding:2px 7px;">{m.kindLabel}</span>
  </div>
  <div style="display:flex; align-items:baseline; gap:8px; margin-top:9px;">
    <h3 style="margin:0; font-size:18px; font-weight:600; color:var(--head);">{m.displayName}</h3>
  </div>
  <div style="font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--accent); min-height:15px;">{m.api}</div>

  <!-- barras métricas -->
  <div style="display:flex; flex-direction:column; gap:8px; margin-top:14px;">
    <div style="display:flex; align-items:center; gap:9px;">
      <span style="width:54px; flex:none; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">In/1M</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:3px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barInPct}; background:var(--accent2); border-radius:3px;`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--head);">{m.priceInText}</span>
    </div>
    <div style="display:flex; align-items:center; gap:9px;">
      <span style="width:54px; flex:none; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">Out/1M</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:3px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barOutPct}; background:var(--accent); border-radius:3px;`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--head);">{m.priceOutText}</span>
    </div>
    <div style="display:flex; align-items:center; gap:9px;">
      <span style="width:54px; flex:none; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">Contexto</span>
      <div style="flex:1; height:8px; background:var(--panel2); border-radius:3px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barCtxPct}; background:var(--warn); border-radius:3px;`}></span></div>
      <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--head);">{m.contextText}</span>
    </div>
    {m.swe != null && (
      <div style="display:flex; align-items:center; gap:9px;">
        <span style="width:54px; flex:none; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.4px;">SWE</span>
        <div style="flex:1; height:8px; background:var(--panel2); border-radius:3px; overflow:hidden;"><span style={`display:block; height:100%; width:${m.barSwePct}; background:var(--pos); border-radius:3px;`}></span></div>
        <span style="width:50px; flex:none; text-align:right; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--pos);">{m.sweText}</span>
      </div>
    )}
  </div>

  <div style="display:flex; flex-wrap:wrap; gap:5px; margin-top:13px;">
    <span style="font-size:10.5px; color:var(--text); background:var(--panel2); border-radius:5px; padding:2px 8px;">{m.originLabel}</span>
    {m.cats.map((cat: string) => (
      <span style="font-size:10.5px; color:var(--dim); background:var(--panel2); border-radius:5px; padding:2px 8px;">{cat}</span>
    ))}
    {m.openWeight && <span style="font-size:10.5px; color:var(--pos); border:1px solid var(--pos); border-radius:5px; padding:1px 7px;">open</span>}
  </div>

  <div style="display:flex; gap:7px; margin-top:14px;">
    <button class="dbtn" data-action="detail" data-id={m.id} style="flex:1; font-family:inherit; font-size:12.5px; padding:8px; border-radius:8px; border:none; background:var(--accent); color:#fff; font-weight:500;">Ver detalle</button>
    <button class="dbtn" data-action="compare" data-id={m.id} style="font-family:inherit; font-size:12.5px; padding:8px 13px; border-radius:8px; border:1px solid var(--border2); background:transparent; color:var(--dim);">+</button>
  </div>
</div>
